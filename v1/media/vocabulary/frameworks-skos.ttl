@prefix media-crosswalk: <https://iqns.org/v0/media-crosswalk#> .
@prefix mg:    <https://iqns.org/v0/medgraph#> .
@prefix ai:    <https://iqns.org/v0/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Media
@prefix owasp:  <https://iqns.org/v0/owasp-llm#> .
@prefix eu-ai:   <https://iqns.org/v0/eu-ai-act#> .

media-crosswalk:Ontology a owl:Ontology ; 
    dct:title "Media AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v0/medgraph#> .

owasp:Framework skos:relatedMatch mg:ContentModeration .
eu-ai:Ontology skos:relatedMatch mg:Drafting . # Art. 50 Synthetic media transparency
