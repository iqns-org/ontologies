@prefix startup: <https://iqns.org/v0/startup#> .
@prefix ai:  <https://iqns.org/v0/ai#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:<http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

startup:Ontology
    a owl:Ontology ;
    dct:title       "StarGraph: Startup and Early-Stage AI Company Core Vocabulary"@en ;
    skos:definition "Abstract vocabulary for startup AI governance — responsibly scaling AI products from MVP to enterprise, managing cross-framework compliance obligations, and AI governance as a product differentiator. Extends ai: with startup-specific maturity dimensions and growth-stage framing."@en ;
    owl:imports     <https://iqns.org/v0/ai#> ;
    owl:versionInfo "0.1" ;
.

# ── Startup Dimensions ────────────────────────────────────────────────────────

startup:RegulatoryReadiness
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Regulatory Readiness"@en ;
    skos:definition "Current and projected compliance posture relative to applicable frameworks — startups must identify their minimum compliance obligations by use-case risk level and target market, then sequence investments to match growth-stage priorities."@en ;
    skos:relatedMatch ai:Accountability ;
.
startup:TrustAndSafety
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Trust and Safety (Product)"@en ;
    skos:definition "Product-level governance controls preventing harms — content moderation, abuse detection, and AI safety guardrails. Proactive investment in trust and safety accelerates enterprise sales and reduces regulatory risk."@en ;
    skos:relatedMatch ai:Safety ;
.
startup:InvestorGovernance
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Investor and Board AI Governance"@en ;
    skos:definition "Board-level AI governance expectations from institutional investors — ESG and responsible AI disclosure requirements; AI risk is increasingly part of venture due diligence."@en ;
    skos:relatedMatch ai:Accountability ;
.
startup:EnterpriseReadiness
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Enterprise AI Compliance Readiness"@en ;
    skos:definition "Ability to satisfy enterprise customer security, privacy, and AI governance requirements — SOC 2, ISO 27001, GDPR DPA, EU AI Act Technical Documentation — required for enterprise sales in regulated industries."@en ;
    skos:relatedMatch ai:Accountability ;
.

# ── Growth Stage Lifecycle ────────────────────────────────────────────────────

startup:MVPStage
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "MVP Stage"@en ;
    skos:definition "Minimum viable product — define AI risk level, implement basic input/output guardrails, establish data handling principles. Minimum: GDPR privacy policy, basic security controls, use-case risk assessment."@en ;
.
startup:ProductMarketFit
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Product-Market Fit"@en ;
    skos:definition "Early scaling — implement SOC 2 Type I, GDPR DPA/SCCs for EU customers, AI use policy, model documentation. First enterprise sales require security questionnaire readiness."@en ;
.
startup:ScaleUp
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Scale-Up"@en ;
    skos:definition "Growth stage — pursue ISO 27001, EU AI Act conformity assessment if deploying high-risk AI, sector-specific certifications (FedRAMP for US government, HIPAA BAA for healthcare). Build compliance programme as product differentiator."@en ;
.
startup:Enterprise
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Enterprise / Late Stage"@en ;
    skos:definition "Full enterprise readiness — complete AI governance programme, market-specific certifications, regulatory engagement, Board AI governance policy, and ESG reporting."@en ;
.

# ── Stakeholders ──────────────────────────────────────────────────────────────

startup:Founder
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Founder / CEO"@en ;
    skos:definition "Startup founder responsible for setting AI governance tone at the top — embedded in AI governance posture decisions from day one."@en ;
.
startup:EnterpriseCustomer
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Enterprise Customer"@en ;
    skos:definition "Large organisation purchasing AI software — primary driver of compliance requirements through vendor security questionnaires, DPAs, and AI governance addenda."@en ;
.
startup:Investor
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Investor (VC / PE)"@en ;
    skos:definition "Venture capital or growth equity investor — increasingly conducting AI governance due diligence; ESG commitments driving AI ethics portfolio standards."@en ;
.
startup:Regulator
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Regulator"@en ;
    skos:definition "Regulatory body with jurisdiction over the startup's AI use cases — DPA (privacy), sector-specific regulator, EU AI Authority (EU AI Act Market Surveillance Authority)."@en ;
.
