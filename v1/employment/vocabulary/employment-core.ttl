@prefix employment-core: <https://iqns.org/v1/emgraph#> .
@prefix ai:  <https://iqns.org/v1/ai#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:<http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

employment-core:Ontology
    a owl:Ontology ;
    dct:title       "EmGraph: Employment and Labour Law Core Vocabulary"@en ;
    skos:definition "Abstract vocabulary for employment law and algorithmic hiring frameworks — covering anti-discrimination, automated hiring, monitoring at work, and worker rights. Extends ai: with employment-specific dimensions, lifecycle stages, and stakeholders."@en ;
    owl:imports     <https://iqns.org/v1/ai#> ;
    owl:versionInfo "0.1" ;
.

# ── Employment-Specific Properties ───────────────────────────────────────────

employment-core:hasProtectedCharacteristic
    a owl:ObjectProperty ;
    skos:prefLabel  "has protected characteristic"@en ;
    rdfs:range  employment-core:ProtectedCharacteristic ;
.
employment-core:appliesToEmploymentStage
    a owl:ObjectProperty ;
    skos:prefLabel  "applies to employment stage"@en ;
    rdfs:range  employment-core:EmploymentStage ;
.
employment-core:isAutomatedDecision
    a owl:DatatypeProperty ;
    skos:prefLabel  "involves automated decision-making"@en ;
    rdfs:range  xsd:boolean ;
.

# ── Protected Characteristics ─────────────────────────────────────────────────

employment-core:Race
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Race / Ethnicity"@en ;
.
employment-core:Sex
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Sex / Gender"@en ;
.
employment-core:Age
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Age"@en ;
.
employment-core:Disability
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Disability"@en ;
.
employment-core:NationalOrigin
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "National Origin"@en ;
.
employment-core:Religion
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Religion or Belief"@en ;
.
employment-core:SexualOrientation
    a employment-core:ProtectedCharacteristic ; a skos:Concept ;
    skos:prefLabel  "Sexual Orientation"@en ;
.

# ── Employment Stages ─────────────────────────────────────────────────────────

employment-core:Recruitment
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Recruitment and Selection"@en ;
    skos:definition "Job advertising, CV screening, candidate ranking, interview scheduling, and hiring decisions — highest AI adoption and regulatory focus."@en ;
.
employment-core:HiringDecision
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Hiring Decision"@en ;
    skos:definition "Final offer/reject decision — if automated or AI-assisted, subject to equal treatment obligations."@en ;
.
employment-core:PerformanceManagement
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Performance Management"@en ;
    skos:definition "Employee performance evaluation, rating, and feedback — AI scoring of worker performance creates disparate impact risk."@en ;
.
employment-core:Promotion
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Promotion and Advancement"@en ;
    skos:definition "Career progression decisions — AI systems making or influencing promotion eligibility must not encode historical bias."@en ;
.
employment-core:Dismissal
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Dismissal and Redundancy"@en ;
    skos:definition "Termination and redundancy selection — algorithm-assisted redundancy selection is high-risk under EU AI Act and EU equal treatment law."@en ;
.
employment-core:WorkerMonitoring
    a employment-core:EmploymentStage ; a skos:Concept ;
    skos:prefLabel  "Worker Monitoring and Surveillance"@en ;
    skos:definition "Productivity tracking, biometric monitoring, keystroke logging, location tracking — regulated under GDPR/EPRIVACY and national employment law."@en ;
.

# ── Dimensions ────────────────────────────────────────────────────────────────

employment-core:EqualTreatment
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Equal Treatment and Non-Discrimination"@en ;
    skos:definition "Prohibition on direct and indirect discrimination based on protected characteristics in employment decisions — core employment law dimension for all AI hiring and management tools."@en ;
    skos:broadMatch ai:Fairness ;
.
employment-core:WorkerDignity
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Worker Dignity"@en ;
    skos:definition "Protection of workers' inherent dignity and right not to be subject to degrading treatment — relevant to AI surveillance, emotion recognition, and intrusive monitoring systems."@en ;
    skos:relatedMatch ai:HumanOversight ;
.
employment-core:WorkplacePrivacy
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Workplace Privacy"@en ;
    skos:definition "Right to a reasonable expectation of privacy in the workplace — limits on monitoring frequency, scope, and purpose; GDPR applies to biometric data processing."@en ;
    skos:broadMatch ai:Privacy ;
.
employment-core:AlgorithmicTransparency
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Algorithmic Transparency in Employment"@en ;
    skos:definition "Workers' right to understand how automated systems affect their employment — explanation of AI-driven hiring and management decisions."@en ;
    skos:broadMatch ai:Transparency ;
.

# ── Stakeholders ──────────────────────────────────────────────────────────────

employment-core:Employer
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Employer"@en ;
    skos:definition "Organisation that employs workers — responsible for ensuring employment AI systems comply with equal treatment obligations."@en ;
.
employment-core:Worker
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Worker / Job Applicant"@en ;
    skos:definition "Individual subject to employer AI decisions — holds rights to non-discrimination, explanation, and challenge of automated employment decisions."@en ;
.
employment-core:LabourInspectorate
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Labour Inspectorate / Equality Body"@en ;
    skos:definition "Regulatory body enforcing employment law and equal treatment obligations — investigates complaints about discriminatory AI hiring tools."@en ;
.
employment-core:TradeUnion
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Trade Union / Works Council"@en ;
    skos:definition "Worker representative body — under EU AI Act Art. 68, AI systems used in employment must be disclosed to works councils or trade unions prior to deployment."@en ;
.
employment-core:HiringTechProvider
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "HR Technology Provider"@en ;
    skos:definition "Third-party vendor supplying AI-powered applicant tracking systems, CV screening, or video interview analysis tools — subject to EU AI Act high-risk obligations as deployer or provider."@en ;
.
