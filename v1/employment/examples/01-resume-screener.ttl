@prefix talent-search: <https://iqns.org/v0/employment/examples/talent-search#> .
@prefix ex:     <https://iqns.org/v0/example#> .
@prefix emg:    <https://iqns.org/v0/emgraph#> .
@prefix ai:     <https://iqns.org/v0/ai#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix eeoc:   <https://iqns.org/v0/eeoc#> .

talent-search:HiringCopilot a ai:System ;
    a emg:Employer ;
    skos:prefLabel "TalentSearch AI Resume Screener"@en ;
    ai:mappedToDimension emg:EqualTreatment ;
    ai:appliesToLifecycle emg:Recruitment ;
    prov:wasDerivedFrom "TalentSearch SaaS Register v2" ;
    # Fairness compliance
    ai:implementsControl eeoc:AdverseImpactStandard ;
    ai:implementsControl eeoc:RecordKeeping ;
.
