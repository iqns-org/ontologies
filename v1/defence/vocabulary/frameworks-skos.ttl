@prefix def-crosswalk: <https://iqns.org/v1/def-crosswalk#> .
@prefix dg:    <https://iqns.org/v1/defgraph#> .
@prefix ai:    <https://iqns.org/v1/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Defence
@prefix nist:   <https://iqns.org/v1/nist-ai-rmf#> .
@prefix ieee7000:   <https://iqns.org/v1/ieee-7000#> .
@prefix pai:    <https://iqns.org/v1/pai-guidelines#> .

def-crosswalk:Ontology a owl:Ontology ; 
    dct:title "Defence AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v1/defgraph#> .

nist:Framework skos:relatedMatch dg:MissionReliability .
ieee7000:Framework skos:relatedMatch dg:MeaningfulHumanControl .
