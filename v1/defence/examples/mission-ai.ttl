@prefix mission-ai: <https://iqns.org/v1/defence/examples/mission-ai#> .
@prefix ex:     <https://iqns.org/v1/example#> .
@prefix defence:     <https://iqns.org/v1/defgraph#> .
@prefix ai:     <https://iqns.org/v1/ai#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix dod:    <https://iqns.org/v1/dod-rai#> .

mission-ai:SentinelUAV a ai:System ;
    a defence:MilitaryCommander ;
    skos:prefLabel "Sentinel Autonomous UAV Reconnaissance"@en ;
    ai:mappedToDimension defence:LegalCompliance ;
    ai:appliesToLifecycle defence:OperationalDeployment ;
    prov:wasDerivedFrom "Sentinel Programme Office - Capability ID S4" ;
    # Ethical AI alignment
    ai:implementsControl dod:AIGovernanceStructure ;
    ai:implementsControl dod:IHLCompliance ;
.
