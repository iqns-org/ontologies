@prefix enterprise-core:   <https://iqns.org/v1/enterprise#> .
@prefix ai:   <https://iqns.org/v1/ai#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

enterprise-core:Ontology
    a owl:Ontology ;
    dct:title       "Enterprise Governance Core Vocabulary"@en ;
    skos:definition "Abstract vocabulary for enterprise governance frameworks."@en ;
    owl:imports     <https://iqns.org/v1/ai#> ;
    owl:versionInfo "0.1" ;
.

# ── Enterprise-Specific Properties ───────────────────────────────────────────
#  — information security, risk management, business continuity, and corporate governance. Extends ai: with enterprise-specific dimensions, lifecycle stages, and stakeholders

enterprise-core:hasMaturityLevel
    a owl:ObjectProperty ;
    skos:prefLabel  "has maturity level"@en ;
    rdfs:range  enterprise-core:MaturityLevel ;
.
enterprise-core:hasControlType
    a owl:ObjectProperty ;
    skos:prefLabel  "has control type"@en ;
    rdfs:range  enterprise-core:ControlType ;
.
enterprise-core:appliesAtOrgLevel
    a owl:ObjectProperty ;
    skos:prefLabel  "applies at organisational level"@en ;
    rdfs:range  enterprise-core:OrgLevel ;
.

# ── Control Types ─────────────────────────────────────────────────────────────

enterprise-core:PreventiveControl
    a enterprise-core:ControlType ; a skos:Concept ;
    skos:prefLabel  "Preventive Control"@en ;
    skos:definition "Control designed to prevent an undesired event from occurring — e.g., access control, encryption, input validation."@en ;
.
enterprise-core:DetectiveControl
    a enterprise-core:ControlType ; a skos:Concept ;
    skos:prefLabel  "Detective Control"@en ;
    skos:definition "Control designed to detect and alert on undesired events — e.g., intrusion detection, anomaly monitoring, audit logging."@en ;
.
enterprise-core:CorrectiveControl
    a enterprise-core:ControlType ; a skos:Concept ;
    skos:prefLabel  "Corrective Control"@en ;
    skos:definition "Control designed to respond to and remediate undesired events — e.g., incident response, backup recovery, patch management."@en ;
.

# ── Maturity Levels ───────────────────────────────────────────────────────────

enterprise-core:Initial
    a enterprise-core:MaturityLevel ; a skos:Concept ;
    skos:prefLabel  "Initial (Ad hoc)"@en ;
    skos:definition "Processes are undocumented and in a state of dynamic change — success depends on individual heroics."@en ;
.
enterprise-core:Managed
    a enterprise-core:MaturityLevel ; a skos:Concept ;
    skos:prefLabel  "Managed (Repeatable)"@en ;
    skos:definition "Processes are documented and partially standardised — basic project management discipline in place."@en ;
.
enterprise-core:Defined
    a enterprise-core:MaturityLevel ; a skos:Concept ;
    skos:prefLabel  "Defined"@en ;
    skos:definition "Processes are documented and standardised across the organisation — consistent application and tailoring."@en ;
.
enterprise-core:Quantitatively
    a enterprise-core:MaturityLevel ; a skos:Concept ;
    skos:prefLabel  "Quantitatively Managed"@en ;
    skos:definition "Processes are controlled using statistical and quantitative techniques — predictable within established metrics."@en ;
.
enterprise-core:Optimising
    a enterprise-core:MaturityLevel ; a skos:Concept ;
    skos:prefLabel  "Optimising"@en ;
    skos:definition "Processes are continuously improved based on quantitative understanding — agile response to change."@en ;
.

# ── Canonical Enterprise Dimensions ──────────────────────────────────────────

ai:InformationSecurity
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Information Security"@en ;
    skos:definition "Confidentiality, Integrity, and Availability (CIA) of information assets — the primary dimension for ISO 27001 and SOC 2."@en ;
    skos:broadMatch ai:Security ;
.
enterprise-core:BusinessContinuity
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Business Continuity"@en ;
    skos:definition "Ability to continue critical business functions during and after a disruption — covers RTO, RPO, disaster recovery, and crisis management."@en ;
    skos:relatedMatch ai:Robustness ;
.
enterprise-core:HealthSafety
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel "Health, Safety, and Environment"@en ;
    skos:definition "Managing employee health, occupational safety, and environmental hazards, including AI-enhanced workplace risk controls."@en ;
    ai:mappedToDimension ai:Safety ;
.
enterprise-core:RiskManagement
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Enterprise Risk Management"@en ;
    skos:definition "Structured approach to identifying, assessing, treating, and monitoring risks across the enterprise — ISO 31000, COSO ERM."@en ;
.
enterprise-core:CorporateGovernance
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Corporate Governance"@en ;
    skos:definition "Structures, processes, and policies by which an organisation is directed and controlled — board oversight, delegation, accountability."@en ;
    skos:broadMatch ai:Accountability ;
.
enterprise-core:SupplyChainRisk
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Supply Chain Risk"@en ;
    skos:definition "Risks arising from third-party vendors, suppliers, and partners — including AI model providers, open-source dependencies, and cloud platforms."@en ;
.

# ── Enterprise Lifecycle ──────────────────────────────────────────────────────

enterprise-core:StrategyAndPlanning
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Strategy and Planning"@en ;
    skos:definition "Risk appetite setting, strategic planning, and governance framework design."@en ;
.
enterprise-core:RiskAssessment
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Risk Identification and Assessment"@en ;
    skos:definition "Systematic identification and evaluation of risks — including AI-specific risk assessments (bias, robustness, third-party AI risk)."@en ;
.
enterprise-core:ControlImplementation
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Control Implementation and Operation"@en ;
    skos:definition "Design and deployment of controls to treat identified risks — technical and organisational measures."@en ;
.
enterprise-core:MonitoringAndReview
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Monitoring, Measurement, and Review"@en ;
    skos:definition "Ongoing monitoring of control effectiveness, KRI/KPI tracking, internal audit, and management review."@en ;
.
enterprise-core:ContinualImprovement
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Continual Improvement"@en ;
    skos:definition "Systematic identification and implementation of improvements — PDCA cycle, lessons learned, corrective and preventive actions."@en ;
.

# ── Stakeholders ──────────────────────────────────────────────────────────────

enterprise-core:BoardDirectors
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Board of Directors"@en ;
    skos:definition "Governing body with ultimate accountability for risk appetite, governance framework, and strategic direction — including AI governance at enterprise level."@en ;
.
enterprise-core:CISO
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "CISO — Chief Information Security Officer"@en ;
    skos:definition "Senior executive accountable for information security strategy, policy, and programme — primary owner of ISO 27001 ISMS."@en ;
.
enterprise-core:CRO
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "CRO — Chief Risk Officer"@en ;
    skos:definition "Senior executive responsible for enterprise risk management framework, risk appetite, and risk reporting to the board."@en ;
.
enterprise-core:InternalAudit
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Internal Audit"@en ;
    skos:definition "Independent assurance function evaluating effectiveness of governance, risk, and control processes — the third line of defence."@en ;
.
enterprise-core:ExternalAuditor
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "External Auditor / Certification Body"@en ;
    skos:definition "Third-party auditor conducting ISO 27001/42001 certification audits or SOC 2 examination — provides independent attestation."@en ;
.
enterprise-core:ThirdPartyVendor
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Third-Party Vendor / Supplier"@en ;
    skos:definition "External organisation providing software, services, or AI models — subject to vendor risk management, contractual security requirements, and supply chain risk controls."@en ;
.
