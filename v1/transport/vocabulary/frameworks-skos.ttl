@prefix tran-crosswalk: <https://iqns.org/v0/tran-crosswalk#> .
@prefix tg:    <https://iqns.org/v0/trangraph#> .
@prefix ai:    <https://iqns.org/v0/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Transport
@prefix iso24027: <https://iqns.org/v0/iso-24027#> .
@prefix iso24028: <https://iqns.org/v0/iso-24028#> .
@prefix iso24029: <https://iqns.org/v0/iso-24029#> .
@prefix eu-ai:    <https://iqns.org/v0/eu-ai-act#> .

tran-crosswalk:Ontology a owl:Ontology ; 
    dct:title "Transport AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v0/trangraph#> .

iso24027:Framework skos:relatedMatch tg:Ontology . # Bias/Fairness in mobility
iso24028:Framework skos:relatedMatch tg:FunctionalSafety . # Trustworthiness
iso24029:Framework skos:relatedMatch tg:FunctionalSafety . # Robustness of NN
eu-ai:Ontology skos:relatedMatch tg:Ontology . # Annex III (2) Critical Infra / Annex II Type Approval
