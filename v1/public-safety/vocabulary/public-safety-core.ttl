@prefix psg: <https://iqns.org/v1/psgraph#> .
@prefix ai:  <https://iqns.org/v1/ai#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:<http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

psg:Ontology
    a owl:Ontology ;
    dct:title       "Public Safety Core Vocabulary"@en ;
    skos:definition "General vocabulary for public safety AI governance"@en ;
    owl:imports     <https://iqns.org/v1/ai#> ;
    owl:versionInfo "0.1" ;
.

# ── Public Safety Dimensions ──────────────────────────────────────────────────

psg:PublicSafetyRisk
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Public Safety Risk"@en ;
    skos:definition "Risk to physical security of persons and property arising from AI system failures or misuse in law enforcement, emergency response, or critical infrastructure contexts."@en ;
    skos:broadMatch ai:Safety ;
.
psg:CivilLibertiesRisk
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Civil Liberties and Fundamental Rights"@en ;
    skos:definition "Risk of AI use in public safety contexts infringing fundamental rights — arbitrary surveillance, biometric mass surveillance, racial profiling, right to privacy, freedom of assembly."@en ;
    skos:relatedMatch ai:Privacy ;
    skos:relatedMatch ai:Fairness ;
    skos:relatedMatch ai:Accountability ;
.
psg:AlgorithmicBiasLawEnforcement
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Algorithmic Bias in Law Enforcement AI"@en ;
    skos:definition "Systematic disparate impact of predictive policing, recidivism scoring, and facial recognition on racial and ethnic minorities — a central concern of EU AI Act Art. 5 prohibited practices and high-risk classification."@en ;
    skos:broadMatch ai:Fairness ;
.
psg:BiometricSurveillance
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Biometric Surveillance"@en ;
    skos:definition "Use of biometric identification technologies in public spaces — EU AI Act prohibits real-time remote biometric identification in public spaces with narrow exceptions; retrospective biometric identification is high-risk."@en ;
    skos:broadMatch ai:Privacy ;
    skos:relatedMatch ai:Safety ;
.

# ── Public Safety Lifecycle ───────────────────────────────────────────────────

psg:PolicingAndInvestigation
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Policing and Investigation"@en ;
    skos:definition "Law enforcement use of AI for crime detection, investigation, and facial recognition — subject to EU AI Act high-risk obligations, GDPR Law Enforcement Directive, and constitutional scrutiny."@en ;
.
psg:RiskAssessmentCriminalJustice
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Risk Assessment in Criminal Justice"@en ;
    skos:definition "AI tools for bail, sentencing, parole, and recidivism risk assessment — EU AI Act high-risk; requires human oversight, explainability, and bias testing across demographic groups."@en ;
.
psg:EmergencyResponse
    a ai:Lifecycle ; a skos:Concept ;
    skos:prefLabel  "Emergency Response and Dispatch"@en ;
    skos:definition "AI-assisted emergency call triage, resource dispatch, and disaster response — high reliability requirements; errors can be life-threatening."@en ;
.

# ── Stakeholders ──────────────────────────────────────────────────────────────

psg:LawEnforcementAgency
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Law Enforcement Agency"@en ;
    skos:definition "Police, border control, or investigative authority deploying AI systems — EU AI Act deployer obligations for high-risk AI; must conduct fundamental rights impact assessments."@en ;
.
psg:AffectedIndividual
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Affected Individual / Suspect"@en ;
    skos:definition "Person subject to law enforcement AI decision — rights: right to explanation of automated decisions, right to human review, right to contest biometric identification."@en ;
.
psg:DataProtectionAuthority
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Data Protection Authority"@en ;
    skos:definition "National authority enforcing GDPR and Law Enforcement Directive (Directive 2016/680) — biometric surveillance and predictive policing AI are within DPA jurisdiction."@en ;
.
psg:CivilSociety
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Civil Society and Oversight Bodies"@en ;
    skos:definition "NGOs, oversight committees, and ombudsmen monitoring law enforcement AI — algorithmic accountability organisations and police oversight bodies."@en ;
.
