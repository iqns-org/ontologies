@prefix ps-crosswalk: <https://iqns.org/v0/ps-crosswalk#> .
@prefix psg:   <https://iqns.org/v0/psgraph#> .
@prefix ai:    <https://iqns.org/v0/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Public Safety
@prefix eu-ai:  <https://iqns.org/v0/eu-ai-act#> .
@prefix nist:   <https://iqns.org/v0/nist-ai-rmf#> .
@prefix mitre:  <https://iqns.org/v0/mitre-atlas#> .

ps-crosswalk:Ontology a owl:Ontology ; 
    dct:title "Public Safety AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v0/psgraph#> .

# EU AI Act Annex III (1, 6, 7) - Biometrics, Law Enforcement, Migration/Border
eu-ai:Ontology skos:relatedMatch psg:Ontology .
nist:Framework skos:relatedMatch psg:PublicSafetyRisk .
mitre:Framework skos:relatedMatch psg:PublicSafetyRisk .
