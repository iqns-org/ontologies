.

aws:OpsWorks
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "OpsWorks"@en ;
    skos:definition     "Configuration management service using Chef or Puppet for infrastructure automation and orchestration."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/opsworks/> ;
    skos:relatedMatch   itil:InfrastructureAndPlatformManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

aws:CloudFormation
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "CloudFormation"@en ;
    skos:definition     "Infrastructure-as-Code service for modelling and provisioning AWS resources using templates."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/cloudformation/> ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:ChangeEnablement ;
.

aws:Config
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Config"@en ;
    skos:definition     "Compliance and configuration tracking service monitoring AWS resource configurations and changes."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/config/> ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:ChangeEnablement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
.

