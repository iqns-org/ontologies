    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
.

# ═══════════════════════════════════════════════════════════════
#  COLLECTIONS
# ═══════════════════════════════════════════════════════════════

aws:ComputeServices
    a skos:Collection ;
    skos:prefLabel "AWS Compute Services"@en ;
    skos:member aws:EC2 ;
    skos:member aws:Lambda ;
    skos:member aws:ECS ;
    skos:member aws:EKS ;
    skos:member aws:AppRunner ;
    skos:member aws:Lightsail ;
.

aws:StorageServices
    a skos:Collection ;
    skos:prefLabel "AWS Storage Services"@en ;
    skos:member aws:S3 ;
    skos:member aws:EBS ;
    skos:member aws:EFS ;
    skos:member aws:FSx ;
    skos:member aws:Glacier ;
.

aws:DatabaseServices
    a skos:Collection ;
    skos:prefLabel "AWS Database Services"@en ;
    skos:member aws:RDS ;
    skos:member aws:DynamoDB ;
    skos:member aws:ElastiCache ;
    skos:member aws:DocumentDB ;
    skos:member aws:Redshift ;
    skos:member aws:Timestream ;
    skos:member aws:Neptune ;
.

aws:NetworkingServices
    a skos:Collection ;
    skos:prefLabel "AWS Networking & CDN Services"@en ;
    skos:member aws:VPC ;
    skos:member aws:ElasticIP ;
    skos:member aws:ELB ;
    skos:member aws:CloudFront ;
    skos:member aws:Route53 ;
    skos:member aws:AppSync ;
.

aws:SecurityServices
    a skos:Collection ;
    skos:prefLabel "AWS Security & Identity Services"@en ;
    skos:member aws:IAM ;
    skos:member aws:KMS ;
    skos:member aws:SecretsManager ;
    skos:member aws:WAF ;
    skos:member aws:SecurityHub ;
.

aws:ManagementServices
    a skos:Collection ;
    skos:prefLabel "AWS Management & Monitoring Services"@en ;
    skos:member aws:CloudWatch ;
    skos:member aws:CloudTrail ;
    skos:member aws:Systems Manager ;
    skos:member aws:OpsWorks ;
    skos:member aws:CloudFormation ;
    skos:member aws:Config ;
.

aws:AnalyticsServices
    a skos:Collection ;
    skos:prefLabel "AWS AI/ML & Analytics Services"@en ;
    skos:member aws:SageMaker ;
    skos:member aws:EMR ;
    skos:member aws:Athena ;
    skos:member aws:Glue ;
.
