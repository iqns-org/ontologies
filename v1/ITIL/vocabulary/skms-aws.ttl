aws:CloudWatch
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "CloudWatch"@en ;
    skos:definition     "Monitoring and observability service collecting metrics, logs, and traces from AWS resources and applications."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/cloudwatch/> ;
    skos:exactMatch     itil:MonitoringAndEventManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

aws:CloudTrail
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "CloudTrail"@en ;
    skos:definition     "API auditing and logging service recording all AWS API calls for compliance and security analysis."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/cloudtrail/> ;
    skos:relatedMatch   itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
.

aws:Systems Manager
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Systems Manager"@en ;
    skos:definition     "Operations service providing visibility and control over AWS infrastructure with automation and patching capabilities."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/systems-manager/> ;
