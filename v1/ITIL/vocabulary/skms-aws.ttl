# ═══════════════════════════════════════════════════════════════

aws:VPC
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "VPC (Virtual Private Cloud)"@en ;
    skos:definition     "Isolated network environment within AWS with configurable IP address space, subnets, route tables, and gateways."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/vpc/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:InformationSecurityManagement ;
.

aws:ElasticIP
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Elastic IP"@en ;
    skos:definition     "Static public IPv4 address for use with EC2 instances and elastic load balancers."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/ec2/elastic-ip/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

aws:ELB
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Elastic Load Balancing (ELB)"@en ;
    skos:definition     "Load balancing service distributing traffic across multiple targets: ALB, NLB, CLB for high availability."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/elasticloadbalancing/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:AvailabilityManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

aws:CloudFront
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "CloudFront"@en ;
    skos:definition     "Content Delivery Network (CDN) service caching and serving content from edge locations globally."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/cloudfront/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
    skos:relatedMatch   itil:MonitoringAndEventManagement ;
.

aws:Route53
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Route 53"@en ;
    skos:definition     "Domain Name System (DNS) and traffic routing service with health checking and failover capabilities."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/route53/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:AvailabilityManagement ;
    skos:relatedMatch   itil:ServiceLevelManagement ;
.

aws:AppSync
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "AppSync"@en ;
    skos:definition     "Managed GraphQL service for building data-driven applications with offline support."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/appsync/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
.

# ═══════════════════════════════════════════════════════════════
#  SECURITY & IDENTITY
# ═══════════════════════════════════════════════════════════════

aws:IAM
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "IAM (Identity and Access Management)"@en ;
    skos:definition     "Service for managing access to AWS resources through users, groups, roles, and policies."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/iam/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:AccessControl ;
    skos:relatedMatch   itil:WorkforceAndTalentManagement ;
.

aws:KMS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "KMS (Key Management Service)"@en ;
    skos:definition     "Managed encryption key service for creating and controlling encryption keys used across AWS services."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/kms/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:ConfigurationItem ;
.

aws:SecretsManager
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Secrets Manager"@en ;
    skos:definition     "Service for storing, rotating, and managing secrets including database credentials and API keys."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/secrets-manager/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:KnowledgeManagement ;
.

aws:WAF
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "WAF (Web Application Firewall)"@en ;
    skos:definition     "Web application firewall protecting applications from common web exploits and DDoS attacks."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/waf/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:RiskManagement ;
.

aws:SecurityHub
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Security Hub"@en ;
    skos:definition     "Centralised security and compliance service providing aggregated security findings and standards checks."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/securityhub/> ;
    skos:relatedMatch   itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
    skos:relatedMatch   itil:RiskManagement ;
.

