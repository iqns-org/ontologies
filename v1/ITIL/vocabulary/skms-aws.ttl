@prefix aws:  <https://iqns.org/v1/itil/aws#> .
@prefix itil: <https://iqns.org/itil#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

aws:Ontology
    a owl:Ontology ;
    dct:title       "Amazon Web Services (AWS) Cloud Service Offerings mapped to ITIL"@en ;
    skos:definition "SKOS concept scheme mapping AWS cloud services to ITIL Service Knowledge Management System practices, configuration items, and service records."@en ;
    prov:wasDerivedFrom <https://aws.amazon.com/> ;
    dct:issued      "2026"^^xsd:gYear ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/itil#> ;
.

aws:AWSScheme
    a skos:ConceptScheme ;
    skos:prefLabel  "AWS Cloud Services"@en ;
    skos:definition "A SKOS scheme mapping AWS cloud offerings to ITIL practices, service components, and configuration item types."@en ;
    dct:publisher   "Amazon Web Services"@en ;
    dct:issued      "2006"^^xsd:gYear ;
.

# ═══════════════════════════════════════════════════════════════
#  COMPUTE & INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════

aws:EC2
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "EC2 (Elastic Compute Cloud)"@en ;
    skos:definition     "On-demand virtual servers (instances) offering compute capacity with configurable CPU, memory, and networking."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/ec2/> ;
    skos:exactMatch     itil:HardwareCI ;
    skos:relatedMatch   itil:InfrastructureAndPlatformManagement ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

aws:Lambda
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Lambda"@en ;
    skos:definition     "Serverless compute service for running code without managing servers, triggered by events or on HTTP requests."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/lambda/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

aws:ECS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "ECS (Elastic Container Service)"@en ;
    skos:definition     "Container orchestration service for running Docker containers at scale."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/ecs/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:AvailabilityManagement ;
.

aws:EKS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "EKS (Elastic Kubernetes Service)"@en ;
    skos:definition     "Managed Kubernetes service for container orchestration and workload management."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/eks/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

aws:AppRunner
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "App Runner"@en ;
    skos:definition     "Fully managed container application service with automatic scaling and deployment."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/apprunner/> ;
    skos:broadMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

aws:Lightsail
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Lightsail"@en ;
    skos:definition     "Simplified virtual private server offering with pre-configured OS and applications."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/lightsail/> ;
    skos:exactMatch     itil:HardwareCI ;
    skos:relatedMatch   itil:InfrastructureAndPlatformManagement ;
.

# ═══════════════════════════════════════════════════════════════
#  STORAGE
# ═══════════════════════════════════════════════════════════════

aws:S3
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "S3 (Simple Storage Service)"@en ;
    skos:definition     "Object storage service for storing and retrieving any amount of data with high durability and availability."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/s3/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:ITAssetManagement ;
.

aws:EBS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "EBS (Elastic Block Store)"@en ;
    skos:definition     "Block storage volumes for use with EC2 instances, offering high-performance persistent storage."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/ebs/> ;
    skos:exactMatch     itil:HardwareCI ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

aws:EFS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "EFS (Elastic File System)"@en ;
    skos:definition     "Managed file system supporting NFS protocol for shared access across EC2 instances."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/efs/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

aws:FSx
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "FSx"@en ;
    skos:definition     "Managed file storage service supporting Windows File Server, Lustre, OpenZFS, and NetApp ONTAP."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/fsx/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

aws:Glacier
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Glacier"@en ;
    skos:definition     "Low-cost archival storage service for long-term data preservation and disaster recovery."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/glacier/> ;
    skos:broadMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceContinuityManagement ;
.

# ═══════════════════════════════════════════════════════════════
#  DATABASES
# ═══════════════════════════════════════════════════════════════

aws:RDS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "RDS (Relational Database Service)"@en ;
    skos:definition     "Managed relational database service supporting SQL engines: PostgreSQL, MySQL, MariaDB, Oracle, SQL Server."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/rds/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
    skos:relatedMatch   itil:ServiceLevelManagement ;
.

aws:DynamoDB
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "DynamoDB"@en ;
    skos:definition     "Fully managed NoSQL key-value database service with automatic scaling and high performance."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/dynamodb/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
    skos:relatedMatch   itil:ServiceLevelManagement ;
.

aws:ElastiCache
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "ElastiCache"@en ;
    skos:definition     "In-memory data cache service supporting Redis and Memcached for improved application latency."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/elasticache/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
    skos:relatedMatch   itil:MonitoringAndEventManagement ;
.

aws:DocumentDB
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "DocumentDB"@en ;
    skos:definition     "Managed MongoDB-compatible database service for document storage and queries."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/documentdb/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

aws:Redshift
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Redshift"@en ;
    skos:definition     "Data warehouse service for analytics on large datasets using columnar storage and parallel query processing."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/redshift/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
.

aws:Timestream
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Timestream"@en ;
    skos:definition     "Time-series database service optimised for storing and querying time-stamped data at scale."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/timestream/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:MonitoringAndEventManagement ;
.

aws:Neptune
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Neptune"@en ;
    skos:definition     "Managed graph database service supporting RDF and property graphs for relationship queries."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/neptune/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:KnowledgeManagement ;
.

