aws:SageMaker
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "SageMaker"@en ;
    skos:definition     "Managed machine learning service for building, training, and deploying ML models at scale."@en ;
    skos:inScheme       aws:AWSScheme ;
