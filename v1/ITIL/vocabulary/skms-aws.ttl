.

aws:EMR
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "EMR (Elastic MapReduce)"@en ;
    skos:definition     "Big data processing framework running Apache Spark, Hadoop, and other tools on EC2 clusters."@en ;
    skos:inScheme       aws:AWSScheme ;
    prov:wasDerivedFrom <https://aws.amazon.com/emr/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

aws:Athena
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Athena"@en ;
    skos:definition     "Serverless SQL query service for analysing data directly in S3 using standard SQL."@en ;
    skos:inScheme       aws:AWSScheme ;
