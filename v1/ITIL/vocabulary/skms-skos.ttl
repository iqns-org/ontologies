# ═══════════════════════════════════════════════════════════════
#  SKOS COLLECTIONS — grouped by theme for navigation
# ═══════════════════════════════════════════════════════════════

itil:GuidingPrinciplesCollection
    a skos:Collection ;
    skos:prefLabel "ITIL v4 Guiding Principles"@en ;
    skos:member itil:FocusOnValue ;
    skos:member itil:StartWhereYouAre ;
    skos:member itil:ProgressIteratively ;
    skos:member itil:CollaborateAndPromoteVisibility ;
    skos:member itil:ThinkAndWorkHolistically ;
    skos:member itil:KeepItSimpleAndPractical ;
    skos:member itil:OptimiseAndAutomate ;
.

itil:ValueChainCollection
    a skos:Collection ;
    skos:prefLabel "Service Value Chain Activities"@en ;
    skos:member itil:Plan ;
    skos:member itil:Improve ;
    skos:member itil:Engage ;
    skos:member itil:DesignAndTransition ;
    skos:member itil:ObtainBuild ;
    skos:member itil:DeliverAndSupport ;
.

itil:SKMSInfrastructureCollection
