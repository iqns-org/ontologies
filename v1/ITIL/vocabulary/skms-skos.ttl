    skos:prefLabel "SKMS Knowledge Infrastructure"@en ;
    skos:member itil:CMDB ;
    skos:member itil:DML ;
    skos:member itil:KnownErrorDatabase ;
    skos:member itil:ServiceCatalogue ;
.

itil:ServiceRecordCollection
