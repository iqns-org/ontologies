tion     "RESTful API and software development kits for infrastructure automation."@en ;    skos:prefLabel      "API & SDK"@en ;    a owl:Class ; a skos:Concept ;do:APIandSDK.    skos:relatedMatch   itil:ServiceConfigurationManagement ;    skos:relatedMatch   itil:ServiceContinuityManagement ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/snapshots/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Point-in-time copies of Droplets and volumes for recovery and provisioning."@en ;    skos:prefLabel      "Snapshots"@en ;    a owl:Class ; a skos:Concept ;do:Snapshots.    skos:relatedMatch   itil:ITAssetManagement ;    skos:relatedMatch   itil:ServiceContinuityManagement ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/backups/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Automatic backup snapshots for Droplets and databases with restore capabilities."@en ;    skos:prefLabel      "Automated Backups"@en ;    a owl:Class ; a skos:Concept ;do:Backups.    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;    skos:relatedMatch   itil:MeasurementAndReporting ;    skos:exactMatch     itil:MonitoringAndEventManagement ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/monitoring/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Monitoring service collecting metrics and alerts for infrastructure resources."@en ;    skos:prefLabel      "Monitoring"@en ;    a owl:Class ; a skos:Concept ;do:Monitoring# ═══════════════════════════════════════════════════════════════#  MONITORING & MANAGEMENT# ═══════════════════════════════════════════════════════════════.    skos:relatedMatch   itil:ServiceConfigurationManagement ;    skos:relatedMatch   itil:InformationSecurityManagement ;    skos:exactMatch     itil:ConfigurationItem ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/cloud-firewalls/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Network firewalls for controlling inbound and outbound traffic to resources."@en ;    skos:prefLabel      "Cloud Firewalls"@en ;    a owl:Class ; a skos:Concept ;do:Firewalls.    skos:relatedMatch   itil:ServiceConfigurationManagement ;    skos:exactMatch     itil:ConfigurationItem ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/dns/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Domain Name System management service for domain hosting and DNS records."@en ;    skos:prefLabel      "Managed DNS"@en ;    a owl:Class ; a skos:Concept ;do:DNS.    skos:relatedMatch   itil:MonitoringAndEventManagement ;    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;    skos:exactMatch     itil:ConfigurationItem ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/cdn/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "CDN service caching content at edge locations for faster global delivery."@en ;    skos:prefLabel      "Content Delivery Network"@en ;    a owl:Class ; a skos:Concept ;do:CDN.    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;    skos:relatedMatch   itil:AvailabilityManagement ;    skos:exactMatch     itil:ConfigurationItem ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/load-balancer/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Load balancing service distributing traffic across Droplets with health checks."@en ;    skos:prefLabel      "Load Balancer"@en ;    a owl:Class ; a skos:Concept ;do:LoadBalancer.    skos:relatedMatch   itil:InformationSecurityManagement ;    skos:relatedMatch   itil:ServiceConfigurationManagement ;    skos:exactMatch     itil:ConfigurationItem ;    prov:wasDerivedFrom <https://www.digitalocean.com/products/vpc/> ;    skos:inScheme       do:DOScheme ;    skos:definition     "Isolated network environment with custom subnets and network policies."@en ;    skos:prefLabel      "Virtual Private Cloud (VPC)"@en ;    a owl:Class ; a skos:Concept ;do:VPC# ═════