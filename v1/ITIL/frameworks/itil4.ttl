@prefix itil4: <https://iqns.org/itil/frameworks/itil4#> .
@prefix itil4: <https://iqns.org/itil#> .
@prefix ai:   <https://iqns.org/v1/ai#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

itil4:Ontology a owl:Ontology ;
    dct:title "ITIL® — IT Infrastructure Library"@en ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
    owl:versionInfo "4.0" ;
    owl:imports <https://iqns.org/itil#> .

itil4:Scheme a skos:ConceptScheme ;
    skos:prefLabel  "ITIL Framework"@en ;
    skos:definition "The current best-practice framework for IT service management, published by AXELOS. Describes the Service Value System, 34 management practices, and 7 guiding principles."@en .

# ── Framework Root ────────────────────────────────────────────────────────────

itil4:ITIL4
    a ai:Framework ; a skos:Concept ;
    skos:prefLabel  "ITIL"@en ;
    skos:definition "IT Infrastructure Library, Fourth Edition. A global ITSM framework providing a practical and flexible basis for supporting organisations on their journey to digital transformation."@en ;
    skos:inScheme   itil4:Scheme ;
    dct:publisher   "AXELOS Limited"@en ;
    dct:issued      "2019"^^xsd:gYear ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
    ai:hasPrinciple  itil4:FocusOnValue ;
    ai:hasPrinciple  itil4:StartWhereYouAre ;
    ai:hasPrinciple  itil4:ProgressIteratively ;
    ai:hasPrinciple  itil4:CollaborateAndPromoteVisibility ;
    ai:hasPrinciple  itil4:ThinkAndWorkHolistically ;
    ai:hasPrinciple  itil4:KeepItSimpleAndPractical ;
    ai:hasPrinciple  itil4:OptimiseAndAutomate ;
.

# ── Service Value System ──────────────────────────────────────────────────────

itil4:ItilSVS
    a itil4:ServiceValueSystem ; a skos:Concept ;
    skos:prefLabel  "ITIL Service Value System"@en ;
    skos:definition "The overarching model showing how ITIL components — Governance, Service Value Chain, 34 Practices, 7 Guiding Principles, and Continual Improvement — interrelate to create value."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil#svs> ;
    itil4:hasValueChainActivity itil4:Plan ;
    itil4:hasValueChainActivity itil4:Improve ;
    itil4:hasValueChainActivity itil4:Engage ;
    itil4:hasValueChainActivity itil4:DesignAndTransition ;
    itil4:hasValueChainActivity itil4:ObtainBuild ;
    itil4:hasValueChainActivity itil4:DeliverAndSupport ;
    itil4:hasPractice itil4:ArchitectureManagement ;
    itil4:hasPractice itil4:ContinualImprovementPractice ;
    itil4:hasPractice itil4:InformationSecurityManagement ;
    itil4:hasPractice itil4:KnowledgeManagement ;
    itil4:hasPractice itil4:MeasurementAndReporting ;
    itil4:hasPractice itil4:OrganisationalChangeManagement ;
    itil4:hasPractice itil4:PortfolioManagement ;
    itil4:hasPractice itil4:ProjectManagement ;
    itil4:hasPractice itil4:RelationshipManagement ;
    itil4:hasPractice itil4:RiskManagement ;
    itil4:hasPractice itil4:ServiceFinancialManagement ;
    itil4:hasPractice itil4:StrategyManagement ;
    itil4:hasPractice itil4:SupplierManagement ;
    itil4:hasPractice itil4:WorkforceAndTalentManagement ;
    itil4:hasPractice itil4:AvailabilityManagement ;
    itil4:hasPractice itil4:BusinessAnalysis ;
    itil4:hasPractice itil4:CapacityAndPerformanceManagement ;
    itil4:hasPractice itil4:ChangeEnablement ;
    itil4:hasPractice itil4:EventManagement ;
    itil4:hasPractice itil4:IncidentManagementPractice ;
    itil4:hasPractice itil4:ITAssetManagement ;
    itil4:hasPractice itil4:MonitoringAndEventManagement ;
    itil4:hasPractice itil4:ProblemManagement ;
    itil4:hasPractice itil4:ReleaseManagement ;
    itil4:hasPractice itil4:ServiceCatalogueManagement ;
    itil4:hasPractice itil4:ServiceConfigurationManagement ;
    itil4:hasPractice itil4:ServiceContinuityManagement ;
    itil4:hasPractice itil4:ServiceDesign ;
    itil4:hasPractice itil4:ServiceDesk ;
    itil4:hasPractice itil4:ServiceLevelManagement ;
    itil4:hasPractice itil4:ServiceRequestManagement ;
    itil4:hasPractice itil4:ServiceValidationAndTesting ;
    itil4:hasPractice itil4:DeploymentManagement ;
    itil4:hasPractice itil4:InfrastructureAndPlatformManagement ;
    itil4:hasPractice itil4:SoftwareDevelopmentAndManagement ;
.

# ── ITIL Roles (Stakeholders) ─────────────────────────────────────────────────

itil4:ServiceProvider
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Service Provider"@en ;
    skos:definition "An organisation that provides services to customers. May be internal (shared services) or external (outsourced)."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
.
itil4:ServiceConsumer
    a ai:Stakeholder ; a skos:Concept ;
    skos:prefLabel  "Service Consumer"@en ;
    skos:definition "A generic term covering customer, user, and sponsor roles that consume services."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
.
itil4:Customer
    a ai:Stakeholder ; a skos:Concept ;
    rdfs:subClassOf itil4:ServiceConsumer ;
    skos:prefLabel  "Customer"@en ;
    skos:definition "A person who defines the requirements for a service and takes responsibility for the outcomes of service consumption."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
.
itil4:User
    a ai:Stakeholder ; a skos:Concept ;
    rdfs:subClassOf itil4:ServiceConsumer ;
    skos:prefLabel  "User"@en ;
    skos:definition "A person who uses services."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
.
itil4:Sponsor
    a ai:Stakeholder ; a skos:Concept ;
    rdfs:subClassOf itil4:ServiceConsumer ;
    skos:prefLabel  "Sponsor"@en ;
    skos:definition "A person who authorises the budget for service consumption."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/what-is-itil> ;
.

# ── The Four Dimensions Model ─────────────────────────────────────────────────

itil4:OrganisationsAndPeople
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Organisations and People"@en ;
    skos:definition "Covers roles, responsibilities, culture, and organisational structures required to facilitate value through services."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom "ITIL — Four Dimensions" ;
    ai:mappedToDimension ai:Accountability ;
.
itil4:InformationAndTechnology
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Information and Technology"@en ;
    skos:definition "Includes knowledge and information managed, and all the technology required to deliver and manage services — platforms, databases, AI tools."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom "ITIL — Four Dimensions" ;
    ai:mappedToDimension ai:Security ;
.
itil4:PartnersAndSuppliers
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Partners and Suppliers"@en ;
    skos:definition "Covers relationships with other organisations involved in the design, deployment, delivery, support, and continual improvement of services."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom "ITIL — Four Dimensions" ;
    ai:mappedToDimension ai:Accountability ;
.
itil4:ValueStreamsAndProcesses
    a ai:Dimension ; a skos:Concept ;
    skos:prefLabel  "Value Streams and Processes"@en ;
    skos:definition "Defines activities, workflows, controls, and procedures to achieve organisational objectives — how parts integrate and coordinate to enable value creation."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom "ITIL — Four Dimensions" ;
    ai:mappedToDimension ai:Transparency ;
.

# ── ITIL Certifications / Publications (provenance trail) ────────────────────

itil4:ITIL4Foundation
    a ai:Assessment ; a skos:Concept ;
    skos:prefLabel  "ITIL Foundation"@en ;
    skos:definition "Entry-level ITIL certification covering ITIL key concepts, the four dimensions, the SVS, and the 34 practices at a foundation level."@en ;
    skos:inScheme   itil4:Scheme ;
    prov:wasDerivedFrom <https://www.axelos.com/certifications/itil-service-management/itil-4-foundation> ;
.

# ── Lifecycle Alignment ───────────────────────────────────────────────────────
# Maps ITIL Value Chain activities to ai: lifecycle stages for cross-domain SPARQL

itil4:Plan              skos:relatedMatch ai:Design .
itil4:Improve           skos:relatedMatch ai:Monitoring .
itil4:Engage            skos:relatedMatch ai:Deployment .
itil4:DesignAndTransition skos:relatedMatch ai:Design .
itil4:ObtainBuild       skos:relatedMatch ai:Development .
itil4:DeliverAndSupport skos:relatedMatch ai:Deployment .

# ── SKOS Alignments to ai: governance dimensions ──────────────────────────────

itil4:ITIL4 ai:mappedToDimension ai:Accountability .
itil4:ITIL4 ai:mappedToDimension ai:Reliability .
itil4:ITIL4 ai:mappedToDimension ai:Security .
itil4:ITIL4 ai:mappedToDimension ai:Transparency .
