@prefix clinic-care: <https://iqns.org/v1/health/examples/clinic-care#> .
@prefix ex:     <https://iqns.org/v1/example#> .
@prefix hg:     <https://iqns.org/v1/healthgraph#> .
@prefix ai:     <https://iqns.org/v1/ai#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix hipaa:  <https://iqns.org/v1/hipaa#> .
@prefix mdr:    <https://iqns.org/v1/eu-mdr#> .

clinic-care:RadiologyAI a ai:System ;
    a hg:ClassIIb ;
    skos:prefLabel "CarePoint Radiology Diagnosis Support"@en ;
    ai:mappedToDimension hg:ClinicalSafety ;
    ai:appliesToLifecycle hg:PostMarketSurveillance ;
    prov:wasDerivedFrom "CarePoint Health Device Registry CRM-10-A" ;
    # Regulatory alignment
    ai:implementsControl hipaa:TechnicalSafeguards ;
    ai:implementsControl mdr:TechnicalDocumentation ;
.
