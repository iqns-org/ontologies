@prefix frameworks-skos: <https://iqns.org/v1/health-crosswalk#> .
@prefix hg:    <https://iqns.org/v1/healthgraph#> .
@prefix ai:    <https://iqns.org/v1/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Health
@prefix fda:    <https://iqns.org/v1/fda-aiml-samd#> .
@prefix iso25:  <https://iqns.org/v1/iso-25059#> .
@prefix onc:    <https://iqns.org/v1/onc-trustworthy#> .

frameworks-skos:Ontology a owl:Ontology ; 
    dct:title "Health AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v1/healthgraph#> .

fda:Framework skos:broadMatch hg:Ontology .
iso25:Framework skos:relatedMatch hg:Ontology .
onc:Framework skos:broadMatch hg:Ontology .
