@prefix ins-crosswalk: <https://iqns.org/v0/ins-crosswalk#> .
@prefix ing:   <https://iqns.org/v0/insgraph#> .
@prefix ai:    <https://iqns.org/v0/ai#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .

# AI Frameworks applicable to Insurance
@prefix eu-ai:  <https://iqns.org/v0/eu-ai-act#> .

ins-crosswalk:Ontology a owl:Ontology ; 
    dct:title "Insurance AI Crosswalk"@en ;
    owl:imports <https://iqns.org/v0/insgraph#> .

# EU AI Act Annex III (5)(b) identifies AI for insurance risk assessment/pricing as high-risk
eu-ai:Ontology skos:relatedMatch ing:Ontology .
