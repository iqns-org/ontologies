# 01-education-integration.rq
# Goal: Find education systems (?this) mapped to academic integrity or student data privacy.

PREFIX gg: <https://iqns.org/v1/ai#>
PREFIX edg: <https://iqns.org/v1/edugraph#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?this ?label ?dimension ?dimensionLabel
WHERE {
    ?this a gg:System ;
          skos:prefLabel ?label ;
          gg:mappedToDimension ?dimension .

    VALUES ?dimension { edg:AcademicIntegrity edg:StudentDataPrivacy }

    ?dimension skos:prefLabel ?dimensionLabel .
}
