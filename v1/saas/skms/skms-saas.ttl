.

skms-saas:Splunk
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Splunk Cloud"@en ;
    skos:definition     "Data platform for searching, monitoring, and analysing machine data and logs."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.splunk.com/> ;
    skos:exactMatch     itil:MonitoringAndEventManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
    skos:relatedMatch   itil:InformationSecurityManagement ;
.

skms-saas:Elastic
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Elastic Cloud (Elasticsearch, Kibana, Beats)"@en ;
    skos:definition     "Search and analytics platform for logs, metrics, and traces."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.elastic.co/cloud/> ;
    skos:exactMatch     itil:MonitoringAndEventManagement ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
.

skms-saas:CloudflareSecuity
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Cloudflare"@en ;
    skos:definition     "Security and performance platform for DDoS protection, WAF, and CDN."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.cloudflare.com/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:RiskManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

skms-saas:Okta
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Okta"@en ;
    skos:definition     "Identity and access management platform for authentication and authorisation."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.okta.com/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:WorkforceAndTalentManagement ;
    skos:relatedMatch   itil:AccessControl ;
.

skms-saas:Auth0
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Auth0"@en ;
    skos:definition     "Authentication and authorisation platform for applications and APIs."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://auth0.com/> ;
    skos:exactMatch     itil:InformationSecurityManagement ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
.

