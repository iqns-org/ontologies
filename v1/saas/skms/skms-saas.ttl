@prefix skms-saas: <https://iqns.org/v1/skms/saas#> .
@prefix itil: <https://iqns.org/itil#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

skms-saas:Ontology
    a owl:Ontology ;
    dct:title       "SaaS & Platform Vendor Service Offerings mapped to ITIL"@en ;
    skos:definition "SKOS concept scheme mapping major SaaS vendors and platforms (Salesforce, Slack, Datadog, GitHub, Atlassian, etc.) to ITIL Service Knowledge Management System practices, configuration items, and service records."@en ;
    dct:issued      "2026"^^xsd:gYear ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/itil#> ;
.

skms-saas:SaaSScheme
    a skos:ConceptScheme ;
    skos:prefLabel  "SaaS & Platform Services"@en ;
    skos:definition "A SKOS scheme mapping major SaaS vendors and platforms to ITIL practices, service components, and configuration item types."@en ;
    dct:issued      "2026"^^xsd:gYear ;
.

# ═══════════════════════════════════════════════════════════════
#  SALESFORCE
# ═══════════════════════════════════════════════════════════════

skms-saas:SalesforceCloud
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Salesforce (Core CRM)"@en ;
    skos:definition     "Customer Relationship Management platform for sales, service, and marketing."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.salesforce.com/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:RelationshipManagement ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

skms-saas:SalesforceCommerceCloud
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Salesforce Commerce Cloud"@en ;
    skos:definition     "E-commerce platform for digital commerce and omnichannel experiences."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.salesforce.com/products/commerce-cloud/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:PortfolioManagement ;
.

skms-saas:SalesforceServiceCloud
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Salesforce Service Cloud"@en ;
    skos:definition     "Customer service platform with case management, knowledge base, and omnichannel support."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.salesforce.com/products/service-cloud/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceDesk ;
    skos:relatedMatch   itil:IncidentManagementPractice ;
.

