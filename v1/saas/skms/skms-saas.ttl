#  COLLECTIONS
# ═══════════════════════════════════════════════════════════════

skms-saas:SalesforceServices
    a skos:Collection ;
    skos:prefLabel "Salesforce Services"@en ;
    skos:member skms-saas:SalesforceCloud ;
    skos:member skms-saas:SalesforceCommerceCloud ;
    skos:member skms-saas:SalesforceServiceCloud ;
.

