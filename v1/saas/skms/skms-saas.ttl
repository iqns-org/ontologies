    a skos:Collection ;
    skos:prefLabel "Communication & Collaboration Services"@en ;
    skos:member skms-saas:Slack ;
    skos:member skms-saas:MicrosoftTeams ;
    skos:member skms-saas:Zoom ;
    skos:member skms-saas:Asana ;
    skos:member skms-saas:Jira ;
    skos:member skms-saas:Confluence ;
    skos:member skms-saas:Miro ;
.

