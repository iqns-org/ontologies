# ═══════════════════════════════════════════════════════════════
#  DEVELOPMENT & CICD  
# ═══════════════════════════════════════════════════════════════

skms-saas:GitHub
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "GitHub"@en ;
    skos:definition     "Version control and DevOps platform for Git repositories with CI/CD pipelines."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://github.com/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:ReleaseManagement ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

skms-saas:GitLab
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "GitLab"@en ;
    skos:definition     "DevOps platform for Git repositories with integrated CI/CD, security, and monitoring."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://gitlab.com/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:InformationSecurityManagement ;
.

skms-saas:Bitbucket
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Bitbucket (Atlassian)"@en ;
    skos:definition     "Git repository management and CI/CD service for distributed teams."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://bitbucket.org/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:ReleaseManagement ;
.

skms-saas:JenkinsCloud
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Jenkins Cloud / Cloud Build Platforms"@en ;
    skos:definition     "Continuous Integration and Continuous Deployment automation platforms."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.jenkins.io/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:ReleaseManagement ;
.

skms-saas:Docker
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Docker Hub & Docker Cloud"@en ;
    skos:definition     "Container management and registry platform for building and sharing container images."@en ;
    skos:inScheme       skms-saas:SaaSScheme ;
    prov:wasDerivedFrom <https://www.docker.com/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

