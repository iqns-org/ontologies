@prefix skms-azure: <https://iqns.org/v1/skms/azure#> .
@prefix itil:  <https://iqns.org/itil#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# ── Ontology ─────────────────────────────────────────────────────────────────

skms-azure:Ontology
    a owl:Ontology ;
    dct:title       "Microsoft Azure Cloud Service Offerings mapped to ITIL"@en ;
    skos:definition "SKOS concept scheme mapping Microsoft Azure cloud services to ITIL Service Knowledge Management System practices, configuration items, and service records."@en ;
    prov:wasDerivedFrom <https://azure.microsoft.com/> ;
    dct:issued      "2026"^^xsd:gYear ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/itil#> ;
.

skms-azure:AzureScheme
    a skos:ConceptScheme ;
    skos:prefLabel  "Microsoft Azure Cloud Services"@en ;
    skos:definition "A SKOS scheme mapping Azure cloud offerings to ITIL practices, service components, and configuration item types."@en ;
    dct:publisher   "Microsoft"@en ;
    dct:issued      "2008"^^xsd:gYear ;
.

# ═══════════════════════════════════════════════════════════════
#  COMPUTE & INFRASTRUCTURE
# ═══════════════════════════════════════════════════════════════

skms-azure:VirtualMachines
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Virtual Machines"@en ;
    skos:definition     "Scalable on-demand computing resources providing Windows and Linux virtual machines."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/virtual-machines/> ;
    skos:exactMatch     itil:HardwareCI ;
    skos:relatedMatch   itil:InfrastructureAndPlatformManagement ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

skms-azure:AppService
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "App Service"@en ;
    skos:definition     "Managed hosting platform for web apps, mobile backends, and RESTful APIs supporting multiple languages."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/app-service/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

skms-azure:Functions
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Azure Functions"@en ;
    skos:definition     "Serverless compute service for running event-driven code without infrastructure management."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/functions/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:DeploymentManagement ;
.

skms-azure:ContainerInstances
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Container Instances"@en ;
    skos:definition     "Simplest way to run containers in Azure without managing virtual machines."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/container-instances/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

skms-azure:AKS
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Azure Kubernetes Service (AKS)"@en ;
    skos:definition     "Managed Kubernetes container orchestration service simplifying deployment and management."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/kubernetes-service/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:DeploymentManagement ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

skms-azure:ServiceFabric
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Service Fabric"@en ;
    skos:definition     "Distributed systems platform for building and managing scalable microservices applications."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/service-fabric/> ;
    skos:exactMatch     itil:SoftwareCI ;
    skos:relatedMatch   itil:SoftwareDevelopmentAndManagement ;
    skos:relatedMatch   itil:AvailabilityManagement ;
.

# ═══════════════════════════════════════════════════════════════
#  STORAGE
# ═══════════════════════════════════════════════════════════════

skms-azure:StorageAccounts
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Storage Accounts"@en ;
    skos:definition     "Managed storage service providing blob, file, queue, and table storage with high availability."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/storage/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
    skos:relatedMatch   itil:ITAssetManagement ;
.

skms-azure:BlobStorage
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Blob Storage"@en ;
    skos:definition     "Object storage for unstructured data including documents, media, and archives."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/storage/blobs/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

skms-azure:FileShare
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Azure Files"@en ;
    skos:definition     "Managed file shares accessible over SMB protocol for cloud-based or on-premises scenarios."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/storage/files/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:ServiceConfigurationManagement ;
.

skms-azure:DataLake
    a owl:Class ; a skos:Concept ;
    skos:prefLabel      "Azure Data Lake Storage"@en ;
    skos:definition     "Massively scalable cloud storage for big data analytics workloads."@en ;
    skos:inScheme       skms-azure:AzureScheme ;
    prov:wasDerivedFrom <https://azure.microsoft.com/en-us/services/storage/data-lake-storage/> ;
    skos:exactMatch     itil:ConfigurationItem ;
    skos:relatedMatch   itil:MeasurementAndReporting ;
    skos:relatedMatch   itil:CapacityAndPerformanceManagement ;
.

