# ═══════════════════════════════════════════════════════════════
#  COLLECTIONS
# ═══════════════════════════════════════════════════════════════

skms-azure:ComputeServices
    a skos:Collection ;
    skos:prefLabel "Azure Compute Services"@en ;
    skos:member skms-azure:VirtualMachines ;
    skos:member skms-azure:AppService ;
    skos:member skms-azure:Functions ;
    skos:member skms-azure:ContainerInstances ;
    skos:member skms-azure:AKS ;
    skos:member skms-azure:ServiceFabric ;
.

skms-azure:StorageServices
    a skos:Collection ;
    skos:prefLabel "Azure Storage Services"@en ;
    skos:member skms-azure:StorageAccounts ;
    skos:member skms-azure:BlobStorage ;
    skos:member skms-azure:FileShare ;
    skos:member skms-azure:DataLake ;
.

skms-azure:DatabaseServices
    a skos:Collection ;
    skos:prefLabel "Azure Database Services"@en ;
    skos:member skms-azure:SQLDatabase ;
    skos:member skms-azure:SQLManagedInstance ;
    skos:member skms-azure:CosmosDB ;
    skos:member skms-azure:TableStorage ;
    skos:member skms-azure:PostgreSQL ;
    skos:member skms-azure:MySQL ;
    skos:member skms-azure:Cache ;
    skos:member skms-azure:DataFactory ;
.

skms-azure:NetworkingServices
    a skos:Collection ;
    skos:prefLabel "Azure Networking Services"@en ;
    skos:member skms-azure:VirtualNetwork ;
    skos:member skms-azure:LoadBalancer ;
    skos:member skms-azure:ApplicationGateway ;
    skos:member skms-azure:CDN ;
    skos:member skms-azure:TrafficManager ;
    skos:member skms-azure:APIManagement ;
.

skms-azure:SecurityServices
    a skos:Collection ;
    skos:prefLabel "Azure Security & Identity Services"@en ;
    skos:member skms-azure:ActiveDirectory ;
    skos:member skms-azure:KeyVault ;
    skos:member skms-azure:Sentinel ;
    skos:member skms-azure:Defender ;
.

skms-azure:ManagementServices
    a skos:Collection ;
    skos:prefLabel "Azure Management & Monitoring Services"@en ;
    skos:member skms-azure:Monitor ;
    skos:member skms-azure:ResourceManager ;
    skos:member skms-azure:UpdateManagement ;
    skos:member skms-azure:Automation ;
    skos:member skms-azure:Advisor ;
.

skms-azure:AnalyticsServices
    a skos:Collection ;
    skos:prefLabel "Azure AI/ML & Analytics Services"@en ;
    skos:member skms-azure:MachineLearning ;
    skos:member skms-azure:Synapse ;
    skos:member skms-azure:StreamAnalytics ;
    skos:member skms-azure:CognitiveServices ;
.
