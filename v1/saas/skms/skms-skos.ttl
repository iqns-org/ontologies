# ── Ontology ─────────────────────────────────────────────────────────────────

skms-skos:SKMSOntology
    a owl:Ontology ;
    dct:title       "ITIL SKMS — SKOS Concept Scheme and Cross-Cutting Collections"@en ;
    skos:definition "SKOS concept scheme for the ITIL Service Knowledge Management System, organising all practices, principles, and record types into navigable collections."@en ;
    owl:imports     <https://iqns.org/itil#> ;
    owl:versionInfo "0.1" ;
.

# ── Top-Level Concept Scheme ──────────────────────────────────────────────────

skms-skos:SKMSScheme
    a skos:ConceptScheme ;
    skos:prefLabel  "ITIL Service Knowledge Management System"@en ;
    skos:definition "A SKOS scheme organising all ITIL concepts: Service Value System, guiding principles, management practices, SKMS knowledge infrastructure, and service record types."@en ;
    dct:publisher   "AXELOS"@en ;
    dct:issued      "2019"^^xsd:gYear ;
.

# ── Top Concepts ──────────────────────────────────────────────────────────────

skms-skos:SKMS          skos:topConceptOf skms-skos:SKMSScheme ; skos:inScheme skms-skos:SKMSScheme .
skms-skos:ServiceValueSystem skos:topConceptOf skms-skos:SKMSScheme ; skos:inScheme skms-skos:SKMSScheme .

