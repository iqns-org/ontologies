@prefix lex-search: <https://iqns.org/v0/legal/examples/lex-search#> .
@prefix ex:     <https://iqns.org/v0/example#> .
@prefix lg:     <https://iqns.org/v0/leggraph#> .
@prefix ai:     <https://iqns.org/v0/ai#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix euai:   <https://iqns.org/v0/eu-ai-act#> .

lex-search:LexSearchAI a ai:System ;
    a lg:Lawyer ;
    skos:prefLabel "LexSearch Legal Research Assistant"@en ;
    ai:mappedToDimension lg:ProfessionalResponsibility ;
    ai:appliesToLifecycle lg:LegalResearch ;
    prov:wasDerivedFrom "LexSearch Product Specification v4.2" ;
    # Professional alignment
    ai:implementsControl euai:HighRiskObligations ;
.
