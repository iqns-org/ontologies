# 01-legal-responsibility.rq
# Goal: Find systems (?this) mapped to professional responsibility or due process dimensions.

PREFIX gg: <https://iqns.org/v0/ai#>
PREFIX lg: <https://iqns.org/v0/leggraph#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?this ?label ?dimension ?dimensionLabel
WHERE {
    ?this a gg:System ;
          skos:prefLabel ?label ;
          gg:mappedToDimension ?dimension .

    VALUES ?dimension { lg:ProfessionalResponsibility lg:DueProcess lg:LegalPrivilege }

    ?dimension skos:prefLabel ?dimensionLabel .
}
