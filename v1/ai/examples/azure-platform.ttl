@prefix azure-platform:      <https://iqns.org/v1/enterprise-example#> .
@prefix ai:      <https://iqns.org/v1/ai#> .
@prefix euai:    <https://iqns.org/v1/eu-ai-act#> .
@prefix nrmf:    <https://iqns.org/v1/nist-ai-rmf#> .
@prefix iso42001:<https://iqns.org/v1/iso-42001#> .
@prefix owasp:   <https://iqns.org/v1/owasp-llm#> .
@prefix saif:    <https://iqns.org/v1/google-saif#> .
@prefix atlas:   <https://iqns.org/v1/mitre-atlas#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

azure-platform:AzureOntology a owl:Ontology ;
    dct:title       "Enterprise Azure AI Platform Assets"@en ;
    skos:definition "Microsoft Azure managed AI/ML service assets used by the enterprise, mapped to IQ:NS controls."@en ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/v1/enterprise-example> ;
.

# ══════════════════════════════════════════════════════════════════════════════
# Azure Machine Learning Workspace
# ══════════════════════════════════════════════════════════════════════════════

azure-platform:AzureMLWorkspace
    a azure-platform:CloudAIPlatform ;
    skos:prefLabel       "Azure Machine Learning Workspace (North Europe)"@en ;
    skos:definition  "Azure ML Workspace in northeurope (Dublin). Hosts compute clusters, managed endpoints, model registry, and dataset store. Used primarily for HR Candidate Screening model training and EU-region batch inference. Azure ML Model Cards and Responsible AI dashboard enabled."@en ;
    azure-platform:vendor        "Microsoft Azure" ;
    azure-platform:dataRegion    "northeurope" ;

    # ── Native controls ───────────────────────────────────────────────────────
    azure-platform:implementsNatively iso42001:A8AILifecycle ;       # end-to-end ML lifecycle (notebooks → pipeline → registry)
    azure-platform:implementsNatively iso42001:A10Documentation ;    # Azure ML Model Cards + experiment lineage
    azure-platform:implementsNatively nrmf:GV5 ;                    # Model Registry = AI system inventory
    azure-platform:implementsNatively nrmf:MS1 ;                    # Responsible AI dashboard: fairness, error analysis
    azure-platform:implementsNatively nrmf:MS3 ;                    # Responsible AI: fairness parity metrics
    azure-platform:implementsNatively nrmf:MS4 ;                    # Azure ML Data Drift detector on managed endpoints
    azure-platform:implementsNatively saif:HarmonisePlatformControls ; # Private Link, Managed Identity, VNet injection
    azure-platform:implementsNatively nrmf:GV6 ;                    # curated environments → base image provenance

    # ── Risks mitigated ───────────────────────────────────────────────────────
    azure-platform:mitigates owasp:LLM10_ModelTheft ;     # model artifacts in ADLS with RBAC + private endpoint
    azure-platform:mitigates atlas:Reconnaissance ;        # no public workspace endpoint when VNet-injected
    azure-platform:mitigates ai:DiscriminationHarm ;       # Responsible AI dashboard enforces fairness review gate

    # ── Residual risks ────────────────────────────────────────────────────────
    azure-platform:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # custom conda environments
    azure-platform:bearsFace atlas:MLAttackStaging ;       # adversarial data submitted via ML pipelines
    azure-platform:bearsFace atlas:PrivilegeEscalation ;   # over-provisioned managed identity
.

# ══════════════════════════════════════════════════════════════════════════════
# Azure OpenAI Service
# ══════════════════════════════════════════════════════════════════════════════

azure-platform:AzureOpenAIService
    a azure-platform:FoundationModelAPI ;
    skos:prefLabel       "Azure OpenAI Service (GPT-4o + Embeddings)"@en ;
    skos:definition  "Azure OpenAI Service deployment in northeurope: GPT-4o (128k context) for RAG Q&A and Azure text-embedding-3-large for vector search. Data residency guaranteed in EU. Content Safety filters enabled. Zero-data-retention (no Microsoft training on prompts). Private endpoint via VNet."@en ;
    azure-platform:vendor        "Microsoft Azure (models: OpenAI)" ;
    azure-platform:dataRegion    "northeurope" ;

    # ── Native controls ───────────────────────────────────────────────────────
    azure-platform:implementsNatively owasp:PromptValidation ;        # Azure Content Safety: jailbreak detection
    azure-platform:implementsNatively owasp:OutputValidation ;        # Content Safety: hate, violence, sexual, self-harm filters
    azure-platform:implementsNatively saif:HarmonisePlatformControls ; # Private endpoint, VNet, Managed Identity
    azure-platform:implementsNatively nrmf:GV6 ;                     # OpenAI responsible AI commitments documented
    azure-platform:implementsNatively euai:TransparencyObligation ;   # AI Notice in API terms; Content Safety usage logs

    # ── Risks mitigated ───────────────────────────────────────────────────────
    azure-platform:mitigates owasp:LLM01_PromptInjection ;         # built-in jailbreak classifier (Prompt Shield)
    azure-platform:mitigates owasp:LLM06_SensitiveInfoDisclosure ; # zero-data-retention policy
    azure-platform:mitigates owasp:LLM10_ModelTheft ;              # opaque API; model weights not extractable

    # ── Residual risks ────────────────────────────────────────────────────────
    azure-platform:bearsFace owasp:LLM08_ExcessiveAgency ;   # Assistants API with tool use can take actions
    azure-platform:bearsFace saif:MemoryPoisoningRAG ;        # retrieval store documents influence outputs
    azure-platform:bearsFace owasp:LLM09_Overreliance ;       # users over-trusting factual accuracy of GPT-4o
    azure-platform:bearsFace euai:GPAIModel ;                 # GPT-4 is GPAI model; Art. 53 disclosure obligations apply
.

# ══════════════════════════════════════════════════════════════════════════════
# Azure AI Content Safety
# ══════════════════════════════════════════════════════════════════════════════

azure-platform:AzureAIContentSafety
    a azure-platform:CloudAIPlatform ;
    skos:prefLabel       "Azure AI Content Safety Service"@en ;
    skos:definition  "Standalone Content Safety API providing real-time content moderation (hate, violence, sexual, self-harm), ground-truth checking, and Prompt Shield (jailbreak + indirect injection detection). Deployed as shared middleware for all LLM workloads (RAG Q&A, Enterprise LLM Assistant)."@en ;
    azure-platform:vendor        "Microsoft Azure" ;
    azure-platform:dataRegion    "northeurope" ;

    # ── Native controls ───────────────────────────────────────────────────────
    azure-platform:implementsNatively owasp:PromptValidation ;        # Prompt Shield: direct + indirect injection
    azure-platform:implementsNatively owasp:OutputValidation ;        # multi-category harm classification on output
    azure-platform:implementsNatively owasp:LeastPrivilegeLLM ;       # content policy enforcement reduces agency scope
    azure-platform:implementsNatively saif:AutomateAIDefences ;       # automated blocking without human-in-the-loop

    # ── Risks mitigated ───────────────────────────────────────────────────────
    azure-platform:mitigates owasp:LLM01_PromptInjection ;
    azure-platform:mitigates owasp:LLM02_InsecureOutputHandling ;
    azure-platform:mitigates owasp:LLM06_SensitiveInfoDisclosure ;

    # ── Upstream for LLM systems ──────────────────────────────────────────────
    azure-platform:upstreamOf azure-platform:RAGDocumentSearch ;
    azure-platform:upstreamOf azure-platform:EnterpriseLLMAssistant ;
.

# ══════════════════════════════════════════════════════════════════════════════
# Microsoft 365 Copilot
# ══════════════════════════════════════════════════════════════════════════════

azure-platform:MSCopilot365
    a azure-platform:SaaSAIService ;
    skos:prefLabel       "Microsoft 365 Copilot"@en ;
    skos:definition  "Microsoft 365 Copilot deployed for 5,000 enterprise users. Integrates with Teams, Outlook, Word, Excel, PowerPoint, and SharePoint. Uses GPT-4 grounded on Microsoft Graph data. EU data boundary opted in. EU AI Act: limited-risk chatbot (Art. 50 disclosure required)."@en ;
    azure-platform:vendor        "Microsoft" ;
    azure-platform:dataRegion    "northeurope, westeurope" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Chatbot interacting with employees → EU AI Act Art. 50 transparency
    azure-platform:implementsNatively euai:TransparencyObligation ;   # Users informed via Microsoft ToS + onboarding notice
    azure-platform:implementsNatively nrmf:GV6 ;                     # Microsoft supply chain governance (SOC2, ISO 27001)
    azure-platform:implementsNatively owasp:OutputValidation ;        # built-in content filters
    azure-platform:implementsNatively saif:HarmonisePlatformControls ; # EU Data Boundary, Entra ID RBAC

    # ── Residual risks ────────────────────────────────────────────────────────
    azure-platform:bearsFace owasp:LLM06_SensitiveInfoDisclosure ;    # M365 Graph access may surface confidential docs
    azure-platform:bearsFace owasp:LLM08_ExcessiveAgency ;            # Copilot actions in Teams/Outlook (email drafting)
    azure-platform:bearsFace owasp:LLM09_Overreliance ;               # executive decisions influenced by Copilot summaries
    azure-platform:bearsFace saif:MemoryPoisoningRAG ;                # SharePoint documents may contain adversarial content
    azure-platform:bearsFace euai:GPAIModel ;                         # uses GPT-4 → GPAI disclosure obligations (Art. 53)
.
