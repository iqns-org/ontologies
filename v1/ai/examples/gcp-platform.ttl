        sr117:ModelUncertainty ; # inherent in XGBoost on tabular credit data
.

# ══════════════════════════════════════════════════════════════════════════════
# M-06  RAG Document Search
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:Mapping_RAGDocSearch
    a gcp-platform:ControlMapping ;
    skos:prefLabel            "Control Mapping — Internal RAG Document Q&A"@en ;
    gcp-platform:asset              gcp-platform:RAGDocumentSearch ;
    gcp-platform:responsibleTeam    "Knowledge Management / Enterprise IT" ;
    gcp-platform:assessmentFrequency "Red-team every 6 months; annual risk assessment" ;

    gcp-platform:applicableRequirement
        euai:TransparencyObligation,
        euai:HumanOversightRequirement ;

    gcp-platform:appliableControl
        nrmf:GV5, nrmf:GV6,
        nrmf:MP1,
        nrmf:MS4, nrmf:MG2,
        iso42001:A9SupplyChain,
        iso42001:A10Documentation,
        owasp:PromptValidation,
        owasp:OutputValidation ;

    gcp-platform:nativeControl
        # Azure OpenAI Service
        owasp:PromptValidation,
        owasp:OutputValidation,
        saif:HarmonisePlatformControls,
        nrmf:GV6,
        euai:TransparencyObligation,
        # Azure AI Content Safety
        owasp:LeastPrivilegeLLM,
        # K8s Istio
        saif:ExpandSecureFoundation,
        nrmf:MS4 ;

    gcp-platform:scheduledAssessment
        ai:RedTeamExercise,
        ai:RiskAssessment ;

    gcp-platform:residualRisk
        saif:MemoryPoisoningRAG,   # adversarial document upload to retrieval store
        atlas:DefenceEvasion ;      # sophisticated prompt crafting bypassing Content Safety
.

