# ══════════════════════════════════════════════════════════════════════════════
# M-08  Code Security Scanner AI
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:Mapping_CodeScanner
    a gcp-platform:ControlMapping ;
    skos:prefLabel            "Control Mapping — AI Code Security Scanner"@en ;
    gcp-platform:asset              gcp-platform:CodeSecurityScannerAI ;
    gcp-platform:responsibleTeam    "Application Security / Platform Engineering" ;
    gcp-platform:assessmentFrequency "Annual risk assessment; quarterly false-negative rate review" ;

    gcp-platform:appliableControl
        nrmf:GV5, nrmf:GV6,
        nrmf:MS4,
        iso42001:A9SupplyChain,
        saif:ExpandSecureFoundation ;

    gcp-platform:nativeControl
        nrmf:GV6,                 # GitHub SOC2 / ISO 27001
        saif:ExpandSecureFoundation ; # K8s hardening

    gcp-platform:scheduledAssessment
        ai:RiskAssessment ;

    gcp-platform:residualRisk
        owasp:LLM09_Overreliance,           # developer behaviour risk — training required
        owasp:LLM05_SupplyChainVulnerabilities ; # Copilot model updates
.

# ══════════════════════════════════════════════════════════════════════════════
# Platform control inheritance — explicit triples for SPARQL traversal
# ══════════════════════════════════════════════════════════════════════════════
#
# These triples explicitly link each platform to the AI systems it hosts,
# making it straightforward to SPARQL-query:
#   "For system X, which controls are native (from its platform) vs owner-owned?"
#
# Pattern: gcp-platform:Platform gcp-platform:hostsSystem gcp-platform:AISystem .

gcp-platform:hostsSystem
    a owl:ObjectProperty ;
    skos:prefLabel   "hosts system"@en ;
    rdfs:comment "This platform hosts (runs inference or training for) the named AI system."@en ;
    rdfs:domain  gcp-platform:Platform ;
    rdfs:range   gcp-platform:AISystem ;
.

gcp-platform:K8sProdCluster      gcp-platform:hostsSystem gcp-platform:EnterpriseLLMAssistant, gcp-platform:RAGDocumentSearch, gcp-platform:CodeSecurityScannerAI .
gcp-platform:AWSBedrockAPI       gcp-platform:hostsSystem gcp-platform:EnterpriseLLMAssistant .
gcp-platform:AWSSageMakerDomain  gcp-platform:hostsSystem gcp-platform:FraudDetectionSystem, gcp-platform:CreditRiskScoringSystem .
gcp-platform:AzureMLWorkspace    gcp-platform:hostsSystem gcp-platform:HRCandidateScreeningSystem .
gcp-platform:AzureOpenAIService  gcp-platform:hostsSystem gcp-platform:RAGDocumentSearch .
gcp-platform:AzureAIContentSafety gcp-platform:hostsSystem gcp-platform:RAGDocumentSearch, gcp-platform:EnterpriseLLMAssistant .
gcp-platform:GCPVertexAIPlatform gcp-platform:hostsSystem gcp-platform:MedicalImagingAI .
gcp-platform:SaaSSalesforceEinstein gcp-platform:hostsSystem gcp-platform:CustomerChurnPredictor .
gcp-platform:SaaSWorkdayAI       gcp-platform:hostsSystem gcp-platform:HRCandidateScreeningSystem .
gcp-platform:SaaSGitHubCopilot   gcp-platform:hostsSystem gcp-platform:CodeSecurityScannerAI .

# ══════════════════════════════════════════════════════════════════════════════
# Governance dimension roll-up
# Explicit mappings of each AI system to the canonical ai: governance
# dimensions it primarily affects — enables dimension-filtered SPARQL queries.
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:EnterpriseLLMAssistant
    ai:mappedToDimension ai:Transparency, ai:HumanOversight, ai:Privacy, ai:Security .

gcp-platform:FraudDetectionSystem
    ai:mappedToDimension ai:Fairness, ai:Accountability, ai:Reliability, ai:Explainability .

gcp-platform:HRCandidateScreeningSystem
    ai:mappedToDimension ai:Fairness, ai:Transparency, ai:HumanOversight, ai:Accountability, ai:Privacy .

gcp-platform:MedicalImagingAI
    ai:mappedToDimension ai:Safety, ai:Reliability, ai:Robustness, ai:Fairness, ai:HumanOversight .

gcp-platform:CreditRiskScoringSystem
    ai:mappedToDimension ai:Fairness, ai:Explainability, ai:Accountability, ai:Transparency .

gcp-platform:RAGDocumentSearch
    ai:mappedToDimension ai:Transparency, ai:Security, ai:Privacy .

gcp-platform:CustomerChurnPredictor
    ai:mappedToDimension ai:Privacy, ai:Fairness .

gcp-platform:CodeSecurityScannerAI
    ai:mappedToDimension ai:Security, ai:Reliability .

# ══════════════════════════════════════════════════════════════════════════════
# Lifecycle stage roll-up
# Maps each AI system to the ai:Lifecycle stages where governance obligations
# are most significant for that system type.
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:EnterpriseLLMAssistant
    ai:appliesToLifecycle ai:Deployment, ai:Operation, ai:Monitoring .

gcp-platform:FraudDetectionSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

gcp-platform:HRCandidateScreeningSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring .

gcp-platform:MedicalImagingAI
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

gcp-platform:CreditRiskScoringSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

gcp-platform:RAGDocumentSearch
    ai:appliesToLifecycle ai:Deployment, ai:Operation, ai:Monitoring .

gcp-platform:CustomerChurnPredictor
    ai:appliesToLifecycle ai:Development, ai:Deployment, ai:Operation, ai:Monitoring .

gcp-platform:CodeSecurityScannerAI
    ai:appliesToLifecycle ai:Deployment, ai:Operation .

# ══════════════════════════════════════════════════════════════════════════════
# Risk treatment decisions
# For each high-risk AI system, state the controls chosen to TREAT (reduce)
# each identified risk, providing an auditable risk treatment record.
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:RiskTreatment_LLMAssistant_PromptInjection
    a gcp-platform:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Prompt Injection — LLM Assistant"@en ;
    gcp-platform:treatsRisk    owasp:LLM01_PromptInjection ;
    gcp-platform:forSystem     gcp-platform:EnterpriseLLMAssistant ;
    gcp-platform:treatedBy
        owasp:PromptValidation,
        gcp-platform:AWSBedrockAPI,        # Bedrock Guardrails: Prompt Shield
        gcp-platform:AzureAIContentSafety ;# secondary content safety layer
.

gcp-platform:RiskTreatment_Fraud_Bias
    a gcp-platform:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Discrimination / Bias — Fraud Detection"@en ;
    gcp-platform:treatsRisk    ai:DiscriminationHarm ;
    gcp-platform:forSystem     gcp-platform:FraudDetectionSystem ;
    gcp-platform:treatedBy
        eba:AIBiasTestingEBA,
        nrmf:MS3,
        sr117:OutcomesAnalysis ;
.

gcp-platform:RiskTreatment_HRScreening_Bias
    a gcp-platform:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Discrimination — HR Screening"@en ;
    gcp-platform:treatsRisk    ai:DiscriminationHarm ;
    gcp-platform:forSystem     gcp-platform:HRCandidateScreeningSystem ;
    gcp-platform:treatedBy
        nrmf:MS3,
        nrmf:MG1,
        euai:HumanOversightRequirement ;
.

gcp-platform:RiskTreatment_MedAI_PhysicalHarm
    a gcp-platform:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Physical Harm — Medical Imaging AI"@en ;
    gcp-platform:treatsRisk    ai:PhysicalHarm ;
    gcp-platform:forSystem     gcp-platform:MedicalImagingAI ;
    gcp-platform:treatedBy
        fda:HumanAITeamPerformance,
        euai:HumanOversightRequirement,
        nrmf:MS4 ;             # real-world performance monitoring triggers alert before harm
.

gcp-platform:RiskTreatment_Credit_Disparate
    a gcp-platform:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Disparate Impact — Credit Risk Scoring"@en ;
    gcp-platform:treatsRisk    ai:DiscriminationHarm ;
    gcp-platform:forSystem     gcp-platform:CreditRiskScoringSystem ;
    gcp-platform:treatedBy
        eba:AIBiasTestingEBA,
        eba:AIModelExplainabilityEBA,
        nrmf:MS3,
        euai:RightToExplanation ; # affected persons entitled to explanation + recourse
.

# ── Helper class (no blank nodes) ────────────────────────────────────────────

gcp-platform:RiskTreatment
    a owl:Class ;
    skos:prefLabel   "Risk Treatment"@en ;
    rdfs:comment "A named risk treatment decision: links a specific risk, the AI system it applies to, and the controls chosen to treat it."@en ;
.
gcp-platform:treatsRisk
    a owl:ObjectProperty ;
    skos:prefLabel   "treats risk"@en ;
    rdfs:domain  gcp-platform:RiskTreatment ;
    rdfs:range   ai:Risk ;
.
gcp-platform:forSystem
    a owl:ObjectProperty ;
    skos:prefLabel   "for system"@en ;
    rdfs:domain  gcp-platform:RiskTreatment ;
    rdfs:range   gcp-platform:AISystem ;
.
gcp-platform:treatedBy
    a owl:ObjectProperty ;
    skos:prefLabel   "treated by"@en ;
    rdfs:domain  gcp-platform:RiskTreatment ;
    rdfs:comment "The control, requirement, or platform feature chosen to treat the risk."@en ;
.
