@prefix gcp-platform:      <https://iqns.org/v1/enterprise-example#> .
@prefix ai:      <https://iqns.org/v1/ai#> .
@prefix euai:    <https://iqns.org/v1/eu-ai-act#> .
@prefix nrmf:    <https://iqns.org/v1/nist-ai-rmf#> .
@prefix iso42001:<https://iqns.org/v1/iso-42001#> .
@prefix owasp:   <https://iqns.org/v1/owasp-llm#> .
@prefix saif:    <https://iqns.org/v1/google-saif#> .
@prefix atlas:   <https://iqns.org/v1/mitre-atlas#> .
@prefix fda:     <https://iqns.org/v1/fda-aiml-samd#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

gcp-platform:GCPOntology a owl:Ontology ;
    dct:title       "Enterprise GCP AI Platform Assets"@en ;
    skos:definition "Google Cloud Platform managed AI/ML service assets used by the enterprise, mapped to IQ:NS controls."@en ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/v1/enterprise-example> ;
.

# ══════════════════════════════════════════════════════════════════════════════
# GCP Vertex AI Platform
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:GCPVertexAIPlatform
    a gcp-platform:CloudAIPlatform ;
    skos:prefLabel       "GCP Vertex AI Platform (us-central1)"@en ;
    skos:definition  "Vertex AI managed ML platform in us-central1 (Iowa). Primary platform for MedicalImagingAI — handles training on NVIDIA A100 clusters, custom model registry, and prediction endpoints with GPU autoscaling. Vertex Explainable AI provides SHAP-based feature attribution for regulatory evidence. FDA-required PCCP (Predetermined Change Control Plan) artefacts stored in Vertex Experiments."@en ;
    gcp-platform:vendor        "Google Cloud" ;
    gcp-platform:dataRegion    "us-central1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    gcp-platform:implementsNatively iso42001:A8AILifecycle ;       # fully managed ML lifecycle
    gcp-platform:implementsNatively iso42001:A10Documentation ;    # Vertex Model Registry + Experiment lineage
    gcp-platform:implementsNatively nrmf:GV5 ;                    # Model Registry doubles as system inventory
    gcp-platform:implementsNatively nrmf:MS1 ;                    # Vertex Explainable AI: SHAP + IG attributions
    gcp-platform:implementsNatively nrmf:MS4 ;                    # Vertex Model Monitoring: skew + drift alerts
    gcp-platform:implementsNatively fda:RealWorldPerformanceMonitoring ; # Model Monitoring data feeds RWPM dashboard
    gcp-platform:implementsNatively fda:GoodMachineLearningPractice ;    # Vertex Experiments captures training provenance
    gcp-platform:implementsNatively saif:HarmonisePlatformControls ;     # VPC-SC, Shared VPC, IAM conditions
    gcp-platform:implementsNatively saif:ContextualisedRiskAssessmentSAIF ; # Vertex AI safety evaluations in model pipeline
    gcp-platform:implementsNatively nrmf:GV6 ;                    # Google supply chain: base container attestations

    # ── Risks mitigated ───────────────────────────────────────────────────────
    gcp-platform:mitigates owasp:LLM10_ModelTheft ;     # model artifacts in GCS with VPC-SC perimeter
    gcp-platform:mitigates atlas:Reconnaissance ;        # Private Service Connect — no public Vertex endpoint
    gcp-platform:mitigates atlas:PrivilegeEscalation ;   # Workload Identity instead of service account keys

    # ── Residual risks ────────────────────────────────────────────────────────
    gcp-platform:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # custom training containers
    gcp-platform:bearsFace atlas:MLAttackStaging ;       # adversarial medical images against prediction endpoint
    gcp-platform:bearsFace atlas:InitialAccess ;         # compromised GCP credentials via phishing
.

# ══════════════════════════════════════════════════════════════════════════════
# BigQuery ML
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:GCPBigQueryML
    a gcp-platform:CloudAIPlatform ;
    skos:prefLabel       "Google BigQuery ML"@en ;
    skos:definition  "BigQuery ML used for in-warehouse exploratory ML: logistic regression, ARIMA forecasting, and k-means clustering on sales and operational data. Models trained on BigQuery datasets without data exfiltration. Output to Looker dashboards. Low-risk analytics use case — no automated decisions."@en ;
    gcp-platform:vendor        "Google Cloud" ;
    gcp-platform:dataRegion    "eu" ;

    # ── Native controls ───────────────────────────────────────────────────────
    gcp-platform:implementsNatively nrmf:GV5 ;          # INFORMATION_SCHEMA.MODELS = lightweight model inventory
    gcp-platform:implementsNatively iso42001:A10Documentation ; # ML.EVALUATE output logged per model
    gcp-platform:implementsNatively saif:HarmonisePlatformControls ; # column-level security, row-level access

    # ── Risks ────────────────────────────────────────────────────────────────
    # Low risk: no real-time inference, no consequential decisions
    gcp-platform:bearsFace ai:PrivacyHarm ;       # personal data in BigQuery datasets used for ML
    gcp-platform:bearsFace ai:FinancialHarm ;     # incorrect forecast influencing procurement decisions
.

# ══════════════════════════════════════════════════════════════════════════════
# GCP Document AI
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:GCPDocumentAI
    a gcp-platform:CloudAIPlatform ;
    skos:prefLabel       "GCP Document AI"@en ;
    skos:definition  "Google Document AI used for automated extraction from medical referral letters, claims forms, and patient intake documents to feed MedicalImagingAI's metadata pipeline. Processes HIPAA-covered PHI — BAA in place with Google. Processes special-category health data."@en ;
    gcp-platform:vendor        "Google Cloud" ;
    gcp-platform:dataRegion    "us-central1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    gcp-platform:implementsNatively nrmf:GV6 ;          # Google HIPAA BAA + healthcare data addendum
    gcp-platform:implementsNatively saif:HarmonisePlatformControls ; # CMEK, VPC-SC, DLP integration
    gcp-platform:implementsNatively nrmf:MS4 ;          # processor version monitoring

    # ── Risks ────────────────────────────────────────────────────────────────
    gcp-platform:bearsFace ai:PrivacyHarm ;             # PHI extraction errors / mis-extraction
    gcp-platform:bearsFace owasp:LLM06_SensitiveInfoDisclosure ; # PHI in extracted fields sent downstream

    # Upstream of Medical Imaging AI metadata pipeline
    gcp-platform:upstreamOf gcp-platform:MedicalImagingAI ;
.

# ══════════════════════════════════════════════════════════════════════════════
# GCP Contact Centre AI
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:GCPContactCenterAI
    a gcp-platform:CloudAIPlatform ;
    skos:prefLabel       "GCP Contact Centre AI (CCAI)"@en ;
    skos:definition  "Dialogflow CX + Agent Assist + Insights for the enterprise's customer support contact centre. CCAI provides real-time agent coaching, intent detection, and post-call sentiment analysis. Interacts with customers — EU AI Act Art. 50 chatbot disclosure required. Voice and text channels."@en ;
    gcp-platform:vendor        "Google Cloud" ;
    gcp-platform:dataRegion    "eu" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Deployed as chatbot/virtual agent interacting with customers → EU AI Act Art. 50
    gcp-platform:implementsNatively euai:TransparencyObligation ;   # Dialogflow: built-in bot disclosure prompts
    gcp-platform:implementsNatively nrmf:GV5 ;                     # CCAI as an inventoried AI system component
    gcp-platform:implementsNatively saif:ContextualisedRiskAssessmentSAIF ; # CCAI risk review in Vertex AI Safety

    # ── Risks ────────────────────────────────────────────────────────────────
    gcp-platform:bearsFace ai:PrivacyHarm ;              # call recordings and transcripts contain PII
    gcp-platform:bearsFace owasp:LLM01_PromptInjection ; # adversarial customer utterances bypassing intent detection
    gcp-platform:bearsFace owasp:LLM09_Overreliance ;    # agents over-trusting CCAI coaching suggestions
    gcp-platform:bearsFace ai:ReputationalHarm ;         # incorrect sentiment analysis influencing NPS reporting
.

        iso42001:A9SupplyChain,
        iso42001:A10Documentation,
        owasp:PromptValidation,
        owasp:OutputValidation,
        owasp:LeastPrivilegeLLM ;

    # Controls natively provided by hosting platforms
    gcp-platform:nativeControl
        # Bedrock Guardrails
        owasp:PromptValidation,    # override: Bedrock does it, but owner must configure
        owasp:OutputValidation,
        # Azure AI Content Safety (if routed through it)
        # K8s Istio
        saif:HarmonisePlatformControls,
        saif:ExpandSecureFoundation,
        nrmf:MS4 ;                 # KServe + Prometheus provides production monitoring

    # Assessments
    gcp-platform:scheduledAssessment
        ai:RedTeamExercise,
        ai:RiskAssessment ;

    # Residual risks after controls applied
    gcp-platform:residualRisk
        owasp:LLM08_ExcessiveAgency,
        owasp:LLM09_Overreliance,
        saif:MemoryPoisoningRAG ;
.

# ══════════════════════════════════════════════════════════════════════════════
# M-02  Fraud Detection System
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:Mapping_FraudDetection
    a gcp-platform:ControlMapping ;
    skos:prefLabel            "Control Mapping — Fraud Detection System"@en ;
    gcp-platform:asset              gcp-platform:FraudDetectionSystem ;
    gcp-platform:responsibleTeam    "Financial Crime / Payments Risk; Model Office (validation)" ;
    gcp-platform:assessmentFrequency "Annual conformity assessment; quarterly SR 11-7 model performance review; monthly bias report" ;

    # Regulatory requirements
    gcp-platform:applicableRequirement
        euai:HighRiskEmployment,
        euai:RiskManagementSystem,
        euai:DataGovernance,
        euai:TechnicalDocumentation,
        euai:RecordKeeping,
        euai:AccuracyRobustnessRequirement,
        euai:ConformityAssessmentRequirement ;

    # Controls — owner responsibility
    gcp-platform:appliableControl
        sr117:ModelDevelopment,
        sr117:ModelDocumentation,
        sr117:ModelTesting,
        sr117:ModelValidation,
        sr117:ConceptualSoundness,
        sr117:OngoingMonitoringSR,
        sr117:OutcomesAnalysis,
        sr117:ModelInventory,
        sr117:ThreeLinesOfDefence,
        eba:AIModelExplainabilityEBA,
        eba:AIBiasTestingEBA,
        eba:DataQualityEBA,
        eba:ModelValidationEBA,
        nrmf:MS1, nrmf:MS3, nrmf:MG1, nrmf:MG2,
        iso42001:A7ResourcesForAI,
        iso42001:A8AILifecycle,
        iso42001:A10Documentation ;

    # SageMaker natively provides
    gcp-platform:nativeControl
        iso42001:A8AILifecycle,
        iso42001:A10Documentation,
        nrmf:GV5,
        nrmf:MS1,
        nrmf:MS3,
        nrmf:MS4,
        sr117:ModelDocumentation,
        sr117:ModelInventory,
        saif:HarmonisePlatformControls ;

    gcp-platform:scheduledAssessment
        ai:BiasAudit,
        ai:RiskAssessment,
        ai:ConformityAssessment ;

    gcp-platform:residualRisk
        ai:DiscriminationHarm,     # ongoing — monitored via fairness dashboard
        atlas:MLAttackStaging ;    # adversary probing; mitigated by rate limiting
.

# ══════════════════════════════════════════════════════════════════════════════
# M-03  HR Candidate Screening System
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:Mapping_HRScreening
    a gcp-platform:ControlMapping ;
    skos:prefLabel            "Control Mapping — HR Candidate Screening System"@en ;
    gcp-platform:asset              gcp-platform:HRCandidateScreeningSystem ;
    gcp-platform:responsibleTeam    "Human Resources / People Analytics; Legal (employment law)" ;
    gcp-platform:assessmentFrequency "Annual conformity assessment (EU AI Act Art. 43); annual bias audit; fundamental rights impact assessment before deployment" ;

    gcp-platform:applicableRequirement
        euai:HighRiskEmployment,
        euai:RiskManagementSystem,
        euai:DataGovernance,
        euai:TechnicalDocumentation,
        euai:RecordKeeping,
        euai:TransparencyObligation,
        euai:HumanOversightRequirement,
        euai:AccuracyRobustnessRequirement,
        euai:EUDatabaseRegistration,
        euai:RightToExplanation,
        euai:ConformityAssessmentRequirement ;

    gcp-platform:appliableControl
        nrmf:GV1, nrmf:GV4, nrmf:GV5, nrmf:GV6,
        nrmf:MP5,
        nrmf:MS2, nrmf:MS3, nrmf:MS4,
        nrmf:MG1, nrmf:MG2,
        iso42001:A5AIPolicy,
        iso42001:A6InternalOrganisation,
        iso42001:A8AILifecycle,
        iso42001:A9SupplyChain,
        iso42001:A10Documentation ;

    gcp-platform:nativeControl
        # Azure ML Workspace
        iso42001:A8AILifecycle,
        iso42001:A10Documentation,
        nrmf:GV5,
        nrmf:MS1,
        nrmf:MS3,
        nrmf:MS4,
        saif:HarmonisePlatformControls,
        # Workday SaaS
        iso42001:A9SupplyChain ;

    gcp-platform:scheduledAssessment
        ai:BiasAudit,
        ai:ImpactAssessment,
        ai:ConformityAssessment,
        ai:RiskAssessment ;

    gcp-platform:residualRisk
        ai:DiscriminationHarm,   # structural — ongoing monitoring required
        ai:SocietalHarm ;        # systemic bias at scale if monitoring fails
.

# ══════════════════════════════════════════════════════════════════════════════
# M-04  Medical Imaging AI
# ══════════════════════════════════════════════════════════════════════════════

gcp-platform:Mapping_MedicalImaging
    a gcp-platform:ControlMapping ;
    skos:prefLabel            "Control Mapping — Medical Imaging AI (Radiology)"@en ;
    gcp-platform:asset              gcp-platform:MedicalImagingAI ;
    gcp-platform:responsibleTeam    "Clinical AI / Health Technology; Regulatory Affairs; Biostatistics" ;
    gcp-platform:assessmentFrequency "FDA 510(k) prior to deployment; EU AI Act conformity assessment; annual clinical performance review; ongoing RWPM per FDA PCCP" ;

    gcp-platform:applicableRequirement
        euai:HighRiskEssentialServices,
        euai:RiskManagementSystem,
        euai:DataGovernance,
        euai:TechnicalDocumentation,
        euai:RecordKeeping,
        euai:HumanOversightRequirement,
        euai:AccuracyRobustnessRequirement,
        euai:PostMarketMonitoring,
        euai:ConformityAssessmentRequirement,
        fda:SoftwareAsMedicalDevice,
        fda:AdaptiveAlgorithm,
        fda:PredeterminedChangeControlPlan,
        fda:AlgorithmChangeProtocol,
        fda:GoodMachineLearningPractice,
        fda:DataRepresentativeness,
        fda:HumanAITeamPerformance,
        fda:RealWorldPerformanceMonitoring,
        fda:TransparencyToUsersPatients ;

    gcp-platform:appliableControl
        nrmf:MS1, nrmf:MS2, nrmf:MS4,
        nrmf:MG2, nrmf:MG3,
        iso42001:A7ResourcesForAI,
        iso42001:A8AILifecycle,
        iso42001:A10Documentation ;

    gcp-platform:nativeControl
        # Vertex AI
        iso42001:A8AILifecycle,
        iso42001:A10Documentation,
        nrmf:GV5,
        nrmf:MS1,
        nrmf:MS4,
        fda:RealWorldPerformanceMonitoring,
        fda:GoodMachineLearningPractice,
        saif:HarmonisePlatformControls,
        saif:ContextualisedRiskAssessmentSAIF,
        # GCP Document AI (upstream)
        nrmf:GV6 ;

    gcp-platform:scheduledAssessment
        ai:RiskAssessment,
        ai:ConformityAssessment,
        ai:BiasAudit,
        ai:RedTeamExercise ;

    gcp-platform:residualRisk
        ai:PhysicalHarm,         # missed diagnosis — radiologist safety net required
        ai:DiscriminationHarm,   # per-demographic performance gap monitoring required
        atlas:MLAttackStaging ;  # adversarial X-ray attacks — ongoing red-team needed
.

