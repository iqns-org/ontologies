        euai:RiskManagementSystem,
        euai:DataGovernance,
        euai:TechnicalDocumentation,
        euai:RecordKeeping,
        euai:HumanOversightRequirement,
        euai:AccuracyRobustnessRequirement,
        euai:RightToExplanation,
        euai:ConformityAssessmentRequirement ;

    gcp-platform:appliableControl
        sr117:ModelDevelopment,
        sr117:ModelDocumentation,
        sr117:ModelTesting,
        sr117:ModelValidation,
        sr117:ConceptualSoundness,
        sr117:OngoingMonitoringSR,
        sr117:OutcomesAnalysis,
        sr117:ModelInventory,
        sr117:ThreeLinesOfDefence,
        sr117:ModelRiskAppetite,
        eba:ICTRiskFramework,
        eba:AIModelExplainabilityEBA,
        eba:AIBiasTestingEBA,
        eba:DataQualityEBA,
        eba:ModelValidationEBA,
        eba:AIGovernanceCommitteeEBA,
        eba:SupervisoryReportingEBA,
        nrmf:MS1, nrmf:MS3, nrmf:MS4,
        nrmf:MG1, nrmf:MG2,
        iso42001:A8AILifecycle,
        iso42001:A10Documentation ;

    gcp-platform:nativeControl
        iso42001:A8AILifecycle,
        iso42001:A10Documentation,
        nrmf:GV5,
        nrmf:MS1,
        nrmf:MS3,
        nrmf:MS4,
        sr117:ModelDocumentation,
        sr117:ModelInventory,
        saif:HarmonisePlatformControls ;

    gcp-platform:scheduledAssessment
        ai:ConformityAssessment,
