# ══════════════════════════════════════════════════════════════════════════════
# Platform control inheritance — explicit triples for SPARQL traversal
# ══════════════════════════════════════════════════════════════════════════════
#
# These triples explicitly link each platform to the AI systems it hosts,
# making it straightforward to SPARQL-query:
#   "For system X, which controls are native (from its platform) vs owner-owned?"
#
# Pattern: ex:Platform ex:hostsSystem ex:AISystem .

ex:hostsSystem
    a owl:ObjectProperty ;
    skos:prefLabel   "hosts system"@en ;
    rdfs:comment "This platform hosts (runs inference or training for) the named AI system."@en ;
    rdfs:domain  ex:Platform ;
    rdfs:range   ex:AISystem ;
.

ex:K8sProdCluster      ex:hostsSystem ex:EnterpriseLLMAssistant, ex:RAGDocumentSearch, ex:CodeSecurityScannerAI .
ex:AWSBedrockAPI       ex:hostsSystem ex:EnterpriseLLMAssistant .
ex:AWSSageMakerDomain  ex:hostsSystem ex:FraudDetectionSystem, ex:CreditRiskScoringSystem .
ex:AzureMLWorkspace    ex:hostsSystem ex:HRCandidateScreeningSystem .
ex:AzureOpenAIService  ex:hostsSystem ex:RAGDocumentSearch .
ex:AzureAIContentSafety ex:hostsSystem ex:RAGDocumentSearch, ex:EnterpriseLLMAssistant .
ex:GCPVertexAIPlatform ex:hostsSystem ex:MedicalImagingAI .
ex:SaaSSalesforceEinstein ex:hostsSystem ex:CustomerChurnPredictor .
ex:SaaSWorkdayAI       ex:hostsSystem ex:HRCandidateScreeningSystem .
ex:SaaSGitHubCopilot   ex:hostsSystem ex:CodeSecurityScannerAI .

# ══════════════════════════════════════════════════════════════════════════════
# Governance dimension roll-up
# Explicit mappings of each AI system to the canonical ai: governance
# dimensions it primarily affects — enables dimension-filtered SPARQL queries.
# ══════════════════════════════════════════════════════════════════════════════

ex:EnterpriseLLMAssistant
    ai:mappedToDimension ai:Transparency, ai:HumanOversight, ai:Privacy, ai:Security .

ex:FraudDetectionSystem
    ai:mappedToDimension ai:Fairness, ai:Accountability, ai:Reliability, ai:Explainability .

ex:HRCandidateScreeningSystem
    ai:mappedToDimension ai:Fairness, ai:Transparency, ai:HumanOversight, ai:Accountability, ai:Privacy .

ex:MedicalImagingAI
    ai:mappedToDimension ai:Safety, ai:Reliability, ai:Robustness, ai:Fairness, ai:HumanOversight .

ex:CreditRiskScoringSystem
    ai:mappedToDimension ai:Fairness, ai:Explainability, ai:Accountability, ai:Transparency .

ex:RAGDocumentSearch
    ai:mappedToDimension ai:Transparency, ai:Security, ai:Privacy .

ex:CustomerChurnPredictor
    ai:mappedToDimension ai:Privacy, ai:Fairness .

ex:CodeSecurityScannerAI
    ai:mappedToDimension ai:Security, ai:Reliability .

# ══════════════════════════════════════════════════════════════════════════════
# Lifecycle stage roll-up
# Maps each AI system to the ai:Lifecycle stages where governance obligations
# are most significant for that system type.
# ══════════════════════════════════════════════════════════════════════════════

ex:EnterpriseLLMAssistant
    ai:appliesToLifecycle ai:Deployment, ai:Operation, ai:Monitoring .

ex:FraudDetectionSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

ex:HRCandidateScreeningSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring .

ex:MedicalImagingAI
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

ex:CreditRiskScoringSystem
    ai:appliesToLifecycle ai:Design, ai:Development, ai:Testing, ai:Deployment, ai:Operation, ai:Monitoring, ai:Retirement .

ex:RAGDocumentSearch
    ai:appliesToLifecycle ai:Deployment, ai:Operation, ai:Monitoring .

ex:CustomerChurnPredictor
    ai:appliesToLifecycle ai:Development, ai:Deployment, ai:Operation, ai:Monitoring .

ex:CodeSecurityScannerAI
    ai:appliesToLifecycle ai:Deployment, ai:Operation .

# ══════════════════════════════════════════════════════════════════════════════
# Risk treatment decisions
# For each high-risk AI system, state the controls chosen to TREAT (reduce)
# each identified risk, providing an auditable risk treatment record.
# ══════════════════════════════════════════════════════════════════════════════

ex:RiskTreatment_LLMAssistant_PromptInjection
    a ex:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Prompt Injection — LLM Assistant"@en ;
    ex:treatsRisk    owasp:LLM01_PromptInjection ;
    ex:forSystem     ex:EnterpriseLLMAssistant ;
    ex:treatedBy
        owasp:PromptValidation,
        ex:AWSBedrockAPI,        # Bedrock Guardrails: Prompt Shield
        ex:AzureAIContentSafety ;# secondary content safety layer
.

ex:RiskTreatment_Fraud_Bias
    a ex:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Discrimination / Bias — Fraud Detection"@en ;
    ex:treatsRisk    ai:DiscriminationHarm ;
    ex:forSystem     ex:FraudDetectionSystem ;
    ex:treatedBy
        eba:AIBiasTestingEBA,
        nrmf:MS3,
        sr117:OutcomesAnalysis ;
.

ex:RiskTreatment_HRScreening_Bias
    a ex:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Discrimination — HR Screening"@en ;
    ex:treatsRisk    ai:DiscriminationHarm ;
    ex:forSystem     ex:HRCandidateScreeningSystem ;
    ex:treatedBy
        nrmf:MS3,
        nrmf:MG1,
        euai:HumanOversightRequirement ;
.

ex:RiskTreatment_MedAI_PhysicalHarm
    a ex:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Physical Harm — Medical Imaging AI"@en ;
    ex:treatsRisk    ai:PhysicalHarm ;
    ex:forSystem     ex:MedicalImagingAI ;
    ex:treatedBy
        fda:HumanAITeamPerformance,
        euai:HumanOversightRequirement,
        nrmf:MS4 ;             # real-world performance monitoring triggers alert before harm
.

ex:RiskTreatment_Credit_Disparate
    a ex:RiskTreatment ;
    skos:prefLabel       "Risk Treatment: Disparate Impact — Credit Risk Scoring"@en ;
    ex:treatsRisk    ai:DiscriminationHarm ;
    ex:forSystem     ex:CreditRiskScoringSystem ;
    ex:treatedBy
        eba:AIBiasTestingEBA,
        eba:AIModelExplainabilityEBA,
        nrmf:MS3,
        euai:RightToExplanation ; # affected persons entitled to explanation + recourse
.

# ── Helper class (no blank nodes) ────────────────────────────────────────────

ex:RiskTreatment
    a owl:Class ;
    skos:prefLabel   "Risk Treatment"@en ;
    rdfs:comment "A named risk treatment decision: links a specific risk, the AI system it applies to, and the controls chosen to treat it."@en ;
.
ex:treatsRisk
    a owl:ObjectProperty ;
    skos:prefLabel   "treats risk"@en ;
    rdfs:domain  ex:RiskTreatment ;
    rdfs:range   ai:Risk ;
.
ex:forSystem
    a owl:ObjectProperty ;
    skos:prefLabel   "for system"@en ;
    rdfs:domain  ex:RiskTreatment ;
    rdfs:range   ex:AISystem ;
.
ex:treatedBy
    a owl:ObjectProperty ;
    skos:prefLabel   "treated by"@en ;
    rdfs:domain  ex:RiskTreatment ;
    rdfs:comment "The control, requirement, or platform feature chosen to treat the risk."@en ;
.
