@prefix k8s-platform:      <https://iqns.org/v1/example#> .
@prefix ai:      <https://iqns.org/v1/ai#> .
@prefix euai:    <https://iqns.org/v1/eu-ai-act#> .
@prefix nrmf:    <https://iqns.org/v1/nist-ai-rmf#> .
@prefix iso42001:<https://iqns.org/v1/iso-42001#> .
@prefix owasp:   <https://iqns.org/v1/owasp-llm#> .
@prefix saif:    <https://iqns.org/v1/google-saif#> .
@prefix atlas:   <https://iqns.org/v1/mitre-atlas#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

k8s-platform:K8sOntology a owl:Ontology ;
    dct:title       "Enterprise Kubernetes AI Platform Assets"@en ;
    skos:definition "Kubernetes container platform assets used to host, train, and serve enterprise AI systems — mapped to IQ:NS controls."@en ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/v1/example> ;
.

# ══════════════════════════════════════════════════════════════════════════════
# Production GPU Kubernetes Cluster
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:K8sProdCluster
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "Production AI/ML Kubernetes Cluster"@en ;
    skos:definition  "Multi-tenant EKS (AWS) Kubernetes 1.30 cluster with dedicated GPU node pools (A100, H100). Hosts model inference, MLflow tracking, Kubeflow Pipelines, and Istio service mesh. Namespaced per BU with RBAC and NetworkPolicy isolation."@en ;
    k8s-platform:vendor        "Kubernetes / Amazon EKS" ;
    k8s-platform:dataRegion    "eu-west-1, us-east-1" ;

    # ── Native controls provided by the platform ──────────────────────────────
    # Namespace + RBAC isolation → reduces lateral movement from MITRE ATLAS PrivilegeEscalation
    k8s-platform:implementsNatively nrmf:GV6 ;   # supply-chain: image provenance via cosign
    k8s-platform:implementsNatively saif:ExpandSecureFoundation ;   # secure-by-default cluster hardening
    k8s-platform:implementsNatively saif:HarmonisePlatformControls ; # consistent RBAC + NetworkPolicy

    # ── Risks this platform introduces ───────────────────────────────────────
    k8s-platform:bearsFace atlas:Reconnaissance ;      # API server exposure to tenant pods
    k8s-platform:bearsFace atlas:PrivilegeEscalation ; # misconfigured RBAC / pod security
    k8s-platform:bearsFace atlas:Persistence ;         # backdoor via compromised container image
    k8s-platform:bearsFace owasp:LLM04_ModelDenialOfService ; # context-window floods exhaust GPU

    # ── Controls the cluster must implement ──────────────────────────────────
    k8s-platform:implementsNatively nrmf:MS4 ; # Prometheus + Grafana dashboards for model endpoints
    k8s-platform:implementsNatively nrmf:MG2 ; # PagerDuty integration for k8s-level incidents
.

# ══════════════════════════════════════════════════════════════════════════════
# KServe — Model Serving Infrastructure
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:KServePlatform
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "KServe Model Serving Platform"@en ;
    skos:definition  "KServe (formerly KFServing) on K8s providing canary rollouts, A/B testing, explainability (SHAP adapter), request/response logging, and auto-scaling for all inference endpoints. Enables model-level observability required by SR 11-7 and EU AI Act."@en ;
    k8s-platform:vendor        "KServe (CNCF)" ;
    k8s-platform:dataRegion    "eu-west-1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    k8s-platform:implementsNatively nrmf:MS4 ;             # request/response logging → drift detection
    k8s-platform:implementsNatively nrmf:MS1 ;             # canary metrics capture
    k8s-platform:implementsNatively iso42001:A10Documentation ; # model serving audit trail
    k8s-platform:implementsNatively saif:ExtendDetectionToAI ;  # model inference telemetry to SIEM

    # Canary rollouts with shadow mode → supports sr117:ModelValidation
    k8s-platform:implementsNatively nrmf:MG1 ;             # traffic routing = risk response mechanism

    # ── Risks mitigated ───────────────────────────────────────────────────────
    k8s-platform:mitigates owasp:LLM04_ModelDenialOfService ; # auto-scaling + rate limiting
    k8s-platform:mitigates atlas:Reconnaissance ;             # mTLS via Istio on all endpoints

    # ── Residual risks ────────────────────────────────────────────────────────
    k8s-platform:bearsFace owasp:LLM10_ModelTheft ;    # model weights accessible from serving pods
    k8s-platform:bearsFace atlas:MLAttackStaging ;     # adversarial inputs to production endpoints
.

# ══════════════════════════════════════════════════════════════════════════════
# MLflow Experiment Tracking & Model Registry
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:MLflowTracking
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "MLflow Model Registry & Experiment Tracking"@en ;
    skos:definition  "MLflow 2.x deployed on K8s with PostgreSQL backend for run metadata and MinIO for artifact storage. All models must be registered here before promotion to KServe. Enforces model lineage, version control, and pre-deployment gate checks."@en ;
    k8s-platform:vendor        "MLflow (Databricks OSS)" ;
    k8s-platform:dataRegion    "eu-west-1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    k8s-platform:implementsNatively iso42001:A8AILifecycle ;     # lifecycle stage gating (Staging → Prod)
    k8s-platform:implementsNatively iso42001:A10Documentation ;  # experiment, dataset, and param lineage
    k8s-platform:implementsNatively nrmf:GV5 ;                  # de-facto AI system inventory
    k8s-platform:implementsNatively nrmf:MS1 ;                  # metric capture per run
    k8s-platform:implementsNatively saif:ExpandSecureFoundation ; # model signing via MLflow Model Signatures

    # ── Risks mitigated ───────────────────────────────────────────────────────
    k8s-platform:mitigates owasp:LLM03_TrainingDataPoisoning ;   # dataset hash stored per registered model
    k8s-platform:mitigates atlas:Persistence ;                   # model version history detects weight tampering

    # ── Residual risks ────────────────────────────────────────────────────────
    k8s-platform:bearsFace atlas:InitialAccess ;       # MLflow UI exposed to internal network
    k8s-platform:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # upstream model artifacts from untrusted sources
.

# ══════════════════════════════════════════════════════════════════════════════
# Kubeflow Pipelines — ML Workflow Automation
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:KubeflowPipelines
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "Kubeflow Pipelines — ML Workflow Orchestration"@en ;
    skos:definition  "Kubeflow Pipelines 2.x on K8s. Orchestrates data ingestion, feature engineering, model training, evaluation, and registration workflows. Each pipeline step is a signed OCI container. Pipeline definitions are version-controlled in Git."@en ;
    k8s-platform:vendor        "Kubeflow (CNCF)" ;
    k8s-platform:dataRegion    "eu-west-1, us-east-1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    k8s-platform:implementsNatively iso42001:A8AILifecycle ;       # end-to-end lifecycle automation
    k8s-platform:implementsNatively nrmf:GV6 ;                    # pipeline dependency SBOM
    k8s-platform:implementsNatively saif:ExpandSecureFoundation ;  # signed container steps
    k8s-platform:implementsNatively nrmf:MP3 ;                    # lifecycle risk identification at each step

    # ── Risks ────────────────────────────────────────────────────────────────
    k8s-platform:bearsFace atlas:MLAttackStaging ;               # malicious pipeline step injection
    k8s-platform:bearsFace owasp:LLM03_TrainingDataPoisoning ;   # upstream data source compromise
    k8s-platform:bearsFace atlas:InitialAccess ;                 # pipeline API exposed to K8s RBAC
.

# ══════════════════════════════════════════════════════════════════════════════
# Istio Service Mesh — mTLS and Traffic Control
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:IstioServiceMesh
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "Istio Service Mesh"@en ;
    skos:definition  "Istio 1.21 providing mTLS between all AI microservices on K8s, traffic management, circuit breaking, rate limiting, and distributed tracing (Jaeger). Critical security boundary between inference endpoints, RAG stores, and data pipelines."@en ;
    k8s-platform:vendor        "Istio / CNCF" ;
    k8s-platform:dataRegion    "eu-west-1, us-east-1" ;

    # ── Native controls ───────────────────────────────────────────────────────
    k8s-platform:implementsNatively saif:HarmonisePlatformControls ; # uniform mTLS + auth policy
    k8s-platform:implementsNatively saif:ExtendDetectionToAI ;       # distributed tracing → SIEM
    k8s-platform:implementsNatively nrmf:MS4 ;                      # latency + error rate metrics

    # ── Risks mitigated ───────────────────────────────────────────────────────
    k8s-platform:mitigates atlas:Reconnaissance ;       # mTLS prevents traffic inspection between pods
    k8s-platform:mitigates atlas:PrivilegeEscalation ;  # AuthorizationPolicy limits service-to-service calls
    k8s-platform:mitigates owasp:LLM01_PromptInjection ; # input/output logged and inspectable

    # ── Residual risks ────────────────────────────────────────────────────────
    k8s-platform:bearsFace atlas:DefenceEvasion ;  # Istio config misconfiguration allowing policy bypass
.

# ══════════════════════════════════════════════════════════════════════════════
# NVIDIA GPU Operator — Compute Management
# ══════════════════════════════════════════════════════════════════════════════

k8s-platform:NVIDIAGPUOperator
    a k8s-platform:ContainerPlatform ;
    skos:prefLabel       "NVIDIA GPU Operator"@en ;
    skos:definition  "NVIDIA GPU Operator managing driver, CUDA, DCGMExporter, and MIG partitioning on K8s GPU nodes. Enables multi-tenant GPU isolation for inference and training workloads. DCGM metrics feed into Prometheus for SLO tracking."@en ;
    k8s-platform:vendor        "NVIDIA" ;

    # ── Native controls ───────────────────────────────────────────────────────
    k8s-platform:implementsNatively nrmf:MS1 ;   # GPU utilisation metrics underpin capacity SLOs
    k8s-platform:implementsNatively nrmf:GV6 ;   # NVIDIA supply chain — driver provenance

    # ── Risks ────────────────────────────────────────────────────────────────
    k8s-platform:bearsFace atlas:PrivilegeEscalation ; # GPU driver CVEs → host escape
    k8s-platform:bearsFace owasp:LLM04_ModelDenialOfService ; # GPU memory exhaustion from adversarial inputs
.
