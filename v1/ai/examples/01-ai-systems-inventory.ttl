@prefix ex:      <https://iqns.org/v0/example#> .
@prefix ai:      <https://iqns.org/v0/ai#> .
@prefix euai:    <https://iqns.org/v0/eu-ai-act#> .
@prefix nrmf:    <https://iqns.org/v0/nist-ai-rmf#> .
@prefix iso42001:<https://iqns.org/v0/iso-42001#> .
@prefix owasp:   <https://iqns.org/v0/owasp-llm#> .
@prefix saif:    <https://iqns.org/v0/google-saif#> .
@prefix atlas:   <https://iqns.org/v0/mitre-atlas#> .
@prefix sr117:   <https://iqns.org/v0/sr-11-7#> .
@prefix eba:     <https://iqns.org/v0/eba-ai#> .
@prefix fda:     <https://iqns.org/v0/fda-aiml-samd#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

ex:Inventory a owl:Ontology ;
    dct:title       "Enterprise AI Systems Inventory"@en ;
    skos:definition "Concrete AI system instances for a hypothetical global enterprise, each mapped to applicable ai: governance controls."@en ;
    prov:wasDerivedFrom      <https://iqns.org/v0/example> ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/v0/example> ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 1.  Enterprise LLM Assistant (EU AI Act: Limited Risk — chatbot disclosure)
# ══════════════════════════════════════════════════════════════════════════════

ex:EnterpriseLLMAssistant
    a ex:GenerativeAISystem ;
    skos:prefLabel              "Enterprise LLM Assistant"@en ;
    skos:definition         "Internal employee-facing generative AI assistant. Answers HR, IT, legal, and strategy questions using RAG over corporate knowledge bases. Backed by AWS Bedrock (Claude) with company-specific fine-tuning and guardrails."@en ;
    ex:systemOwner          "Digital Workplace / IT Platform team" ;
    ex:processesPersonalData true ;
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         true ;
    ex:dataRegion           "eu-west-1, us-east-1" ;
    ex:hostedOn             ex:K8sProdCluster, ex:AWSBedrockAPI ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    # Chatbot disclosure obligation applies (EU AI Act Art. 50)
    ex:riskClassifiedAs     euai:LimitedRisk ;
    ex:subjectToRequirement euai:TransparencyObligation ;     # disclose AI nature to users
    ex:subjectToRequirement euai:HumanOversightRequirement ;  # escalation path to humans

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:GV1 ;   # AI policy & accountability
    ex:subjectToControl nrmf:GV5 ;   # AI risk & benefits inventory
    ex:subjectToControl nrmf:GV6 ;   # third-party / supply chain (Bedrock, Anthropic)
    ex:subjectToControl nrmf:MP1 ;   # context documentation (intended users, use cases)
    ex:subjectToControl nrmf:MP2 ;   # risk category classification
    ex:subjectToControl nrmf:MS2 ;   # red-team / adversarial testing
    ex:subjectToControl nrmf:MS4 ;   # production performance monitoring
    ex:subjectToControl nrmf:MG2 ;   # AI incident response

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A9SupplyChain ;      # manage Bedrock/Anthropic vendor
    ex:subjectToControl iso42001:A10Documentation ;   # model card + RAG data provenance

    # ── OWASP LLM risks (this system must mitigate all 10) ───────────────────
    ex:bearsFace owasp:LLM01_PromptInjection ;
    ex:bearsFace owasp:LLM02_InsecureOutputHandling ;
    ex:bearsFace owasp:LLM03_TrainingDataPoisoning ;  # fine-tuning data
    ex:bearsFace owasp:LLM04_ModelDenialOfService ;
    ex:bearsFace owasp:LLM05_SupplyChainVulnerabilities ;
    ex:bearsFace owasp:LLM06_SensitiveInfoDisclosure ;
    ex:bearsFace owasp:LLM08_ExcessiveAgency ;
    ex:bearsFace owasp:LLM09_Overreliance ;
    ex:bearsFace owasp:LLM10_ModelTheft ;
    ex:bearsFace saif:MemoryPoisoningRAG ;            # RAG store injection

    # ── Controls to implement ─────────────────────────────────────────────────
    ex:subjectToControl owasp:PromptValidation ;
    ex:subjectToControl owasp:OutputValidation ;
    ex:subjectToControl owasp:LeastPrivilegeLLM ;

    # ── Assessments required ──────────────────────────────────────────────────
    ex:requiresAssessment ai:RedTeamExercise ;
    ex:requiresAssessment ai:RiskAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 2.  Fraud Detection System (High Risk: SR 11-7 model risk; EBA AI)
# ══════════════════════════════════════════════════════════════════════════════

ex:FraudDetectionSystem
    a ex:ClassicalMLSystem ;
    skos:prefLabel              "Real-Time Fraud Detection System"@en ;
    skos:definition         "Gradient-boosted ensemble model scoring card transactions in <50 ms. Trained on 3 years of labelled fraud events. Deployed as a SageMaker real-time endpoint with A/B shadow model. Subject to SR 11-7 model risk management and EBA AI guidelines."@en ;
    ex:systemOwner          "Financial Crime / Payments Risk team" ;
    ex:processesPersonalData true ;
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         false ;
    ex:dataRegion           "eu-central-1" ;
    ex:hostedOn             ex:AWSSageMakerDomain ;
    ex:deployedInDomain     ai:Finance ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    # SR 11-7 (US banking regulator) — model risk; EBA AI guidelines (EU banking)
    # EU AI Act: financial services access → HighRisk (Annex III)
    ex:riskClassifiedAs     ai:HighRisk ;                         # canonical
    ex:subjectToRequirement euai:HighRiskEmployment ;              # closest EU AI Act bucket
    ex:subjectToRequirement euai:RiskManagementSystem ;
    ex:subjectToRequirement euai:DataGovernance ;
    ex:subjectToRequirement euai:TechnicalDocumentation ;
    ex:subjectToRequirement euai:RecordKeeping ;
    ex:subjectToRequirement euai:AccuracyRobustnessRequirement ;
    ex:requiresAssessment   euai:ConformityAssessmentRequirement ; # EU AI Act Art. 43

    # ── SR 11-7 controls ─────────────────────────────────────────────────────
    ex:subjectToControl sr117:ModelDevelopment ;
    ex:subjectToControl sr117:ModelDocumentation ;
    ex:subjectToControl sr117:ModelTesting ;
    ex:subjectToControl sr117:ModelValidation ;
    ex:subjectToControl sr117:ConceptualSoundness ;
    ex:subjectToControl sr117:OngoingMonitoringSR ;
    ex:subjectToControl sr117:OutcomesAnalysis ;
    ex:subjectToControl sr117:ModelInventory ;
    ex:subjectToControl sr117:ThreeLinesOfDefence ;

    # ── EBA AI controls ───────────────────────────────────────────────────────
    ex:subjectToControl eba:AIModelExplainabilityEBA ;
    ex:subjectToControl eba:AIBiasTestingEBA ;
    ex:subjectToControl eba:DataQualityEBA ;
    ex:subjectToControl eba:ModelValidationEBA ;

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:MS1 ;   # risk metrics & threshold testing
    ex:subjectToControl nrmf:MS3 ;   # bias & fairness evaluation (false-positive disparity)
    ex:subjectToControl nrmf:MS4 ;   # production performance / drift monitoring
    ex:subjectToControl nrmf:MG1 ;   # risk response (model override process)
    ex:subjectToControl nrmf:MG2 ;   # incident response for model failures

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A7ResourcesForAI ;
    ex:subjectToControl iso42001:A8AILifecycle ;
    ex:subjectToControl iso42001:A10Documentation ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace sr117:ModelRisk ;
    ex:bearsFace sr117:ModelUncertainty ;
    ex:bearsFace ai:DiscriminationHarm ;     # false-positive rate disparity across demographics
    ex:bearsFace ai:FinancialHarm ;          # missed fraud causing losses
    ex:bearsFace atlas:MLAttackStaging ;     # adversary probing decision thresholds

    # ── Assessments required ──────────────────────────────────────────────────
    ex:requiresAssessment ai:BiasAudit ;
    ex:requiresAssessment ai:RiskAssessment ;
    ex:requiresAssessment ai:ConformityAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 3.  HR Candidate Screening System  (EU AI Act: HIGH RISK — Annex III §4)
# ══════════════════════════════════════════════════════════════════════════════

ex:HRCandidateScreeningSystem
    a ex:ClassicalMLSystem ;
    skos:prefLabel              "HR Candidate Screening & Ranking System"@en ;
    skos:definition         "ML model ranking job applicants by predicted interview-success probability. Ingests CV text + LinkedIn data; deployed as Azure ML batch scoring pipeline, also integrated with Workday ATS. Employment domain → HIGH RISK under EU AI Act Annex III §4."@en ;
    ex:systemOwner          "Human Resources / People Analytics team" ;
    ex:processesPersonalData true ;
    ex:processesSpecialCategoryData false ; # no protected characteristics used as features
    ex:thirdPartyAI         true ;          # Workday AI component
    ex:dataRegion           "eu-west-1" ;
    ex:hostedOn             ex:AzureMLWorkspace, ex:SaaSWorkdayAI ;
    ex:deployedInDomain     ai:Employment ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    # EU AI Act Annex III §4 — employment & worker management → HIGH RISK
    ex:riskClassifiedAs         ai:HighRisk ;
    ex:subjectToRequirement     euai:HighRiskEmployment ;
    ex:subjectToRequirement     euai:RiskManagementSystem ;
    ex:subjectToRequirement     euai:DataGovernance ;
    ex:subjectToRequirement     euai:TechnicalDocumentation ;
    ex:subjectToRequirement     euai:RecordKeeping ;
    ex:subjectToRequirement     euai:TransparencyObligation ;
    ex:subjectToRequirement     euai:HumanOversightRequirement ;
    ex:subjectToRequirement     euai:AccuracyRobustnessRequirement ;
    ex:subjectToRequirement     euai:EUDatabaseRegistration ;

    # Affected persons have right to explanation of automated processing
    ex:subjectToRequirement     euai:RightToExplanation ;

    # Conformity assessment required before deployment
    ex:requiresAssessment       euai:ConformityAssessmentRequirement ;

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:GV1 ;   # top-level AI accountability policy
    ex:subjectToControl nrmf:GV4 ;   # stakeholder engagement (HR, legal, works council)
    ex:subjectToControl nrmf:GV5 ;   # AI system inventory
    ex:subjectToControl nrmf:GV6 ;   # Workday third-party supply-chain risk
    ex:subjectToControl nrmf:MP5 ;   # fundamental rights & employment law impact
    ex:subjectToControl nrmf:MS2 ;   # red-team: test for demographic bias
    ex:subjectToControl nrmf:MS3 ;   # bias & fairness evaluation (mandatory)
    ex:subjectToControl nrmf:MS4 ;   # ongoing performance monitoring per role/region
    ex:subjectToControl nrmf:MG1 ;   # human review override for every shortlist
    ex:subjectToControl nrmf:MG2 ;   # incident response if discriminatory pattern detected

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A5AIPolicy ;
    ex:subjectToControl iso42001:A6InternalOrganisation ;
    ex:subjectToControl iso42001:A8AILifecycle ;
    ex:subjectToControl iso42001:A9SupplyChain ;    # Workday AI vendor management
    ex:subjectToControl iso42001:A10Documentation ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace ai:DiscriminationHarm ;    # gender, ethnicity, disability proxy features
    ex:bearsFace ai:PrivacyHarm ;           # CV data profiling
    ex:bearsFace ai:ReputationalHarm ;      # discriminatory outcomes made public
    ex:bearsFace ai:SocietalHarm ;          # systemic discrimination at scale

    # ── Assessments required ──────────────────────────────────────────────────
    ex:requiresAssessment ai:BiasAudit ;
    ex:requiresAssessment ai:ImpactAssessment ;
    ex:requiresAssessment ai:ConformityAssessment ;
    ex:requiresAssessment ai:RiskAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 4.  Medical Imaging AI (EU AI Act: HIGH RISK; FDA SaMD Class II)
# ══════════════════════════════════════════════════════════════════════════════

ex:MedicalImagingAI
    a ex:ClassicalMLSystem ;   # deep CNN — still classical-ML in regulatory sense
    skos:prefLabel              "Radiology AI — Chest X-Ray Triage"@en ;
    skos:definition         "Deep learning model detecting pneumonia, COVID-19 consolidation, and pneumothorax in chest radiographs. Deployed on GCP Vertex AI with GPU inference. FDA 510(k) cleared Class II SaMD. EU AI Act Annex III §5 (healthcare) — HIGH RISK."@en ;
    ex:systemOwner          "Clinical AI / Health Technology team" ;
    ex:processesPersonalData true ;
    ex:processesSpecialCategoryData true ;  # health data = GDPR Art. 9
    ex:thirdPartyAI         false ;
    ex:dataRegion           "us-central1" ;
    ex:hostedOn             ex:GCPVertexAIPlatform ;
    ex:deployedInDomain     ai:Healthcare ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    ex:riskClassifiedAs         ai:HighRisk ;
    ex:subjectToRequirement     euai:HighRiskEssentialServices ; # healthcare → Annex III §5
    ex:subjectToRequirement     euai:RiskManagementSystem ;
    ex:subjectToRequirement     euai:DataGovernance ;
    ex:subjectToRequirement     euai:TechnicalDocumentation ;
    ex:subjectToRequirement     euai:RecordKeeping ;
    ex:subjectToRequirement     euai:HumanOversightRequirement ;  # radiologist review required
    ex:subjectToRequirement     euai:AccuracyRobustnessRequirement ;
    ex:subjectToRequirement     euai:PostMarketMonitoring ;
    ex:requiresAssessment       euai:ConformityAssessmentRequirement ;

    # ── FDA SaMD controls (US) ────────────────────────────────────────────────
    ex:subjectToRequirement fda:SoftwareAsMedicalDevice ;
    ex:subjectToRequirement fda:AdaptiveAlgorithm ;
    ex:subjectToRequirement fda:PredeterminedChangeControlPlan ;
    ex:subjectToRequirement fda:AlgorithmChangeProtocol ;
    ex:subjectToRequirement fda:GoodMachineLearningPractice ;
    ex:subjectToRequirement fda:DataRepresentativeness ;
    ex:subjectToRequirement fda:HumanAITeamPerformance ;
    ex:subjectToRequirement fda:RealWorldPerformanceMonitoring ;
    ex:subjectToRequirement fda:TransparencyToUsersPatients ;

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:MS1 ;   # sensitivity, specificity, AUC thresholds
    ex:subjectToControl nrmf:MS2 ;   # adversarial robustness (image perturbation)
    ex:subjectToControl nrmf:MS4 ;   # real-world performance monitoring
    ex:subjectToControl nrmf:MG2 ;   # clinical incident response protocol
    ex:subjectToControl nrmf:MG3 ;   # decommission plan when model accuracy degrades

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A7ResourcesForAI ;  # training data provenance
    ex:subjectToControl iso42001:A8AILifecycle ;
    ex:subjectToControl iso42001:A10Documentation ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace ai:PhysicalHarm ;          # missed diagnosis or false alarm
    ex:bearsFace ai:DiscriminationHarm ;    # performance disparity across ethnic groups
    ex:bearsFace ai:PrivacyHarm ;           # PHI in training data
    ex:bearsFace atlas:MLAttackStaging ;    # adversarial X-ray perturbation attacks

    # ── Assessments required ──────────────────────────────────────────────────
    ex:requiresAssessment ai:RiskAssessment ;
    ex:requiresAssessment ai:ConformityAssessment ;
    ex:requiresAssessment ai:BiasAudit ;       # per FDA — disaggregated by demographics
    ex:requiresAssessment ai:RedTeamExercise ; # adversarial image testing
.

# ══════════════════════════════════════════════════════════════════════════════
# 5.  Credit Risk Scoring System (High Risk: SR 11-7; EBA; EU AI Act)
# ══════════════════════════════════════════════════════════════════════════════

ex:CreditRiskScoringSystem
    a ex:ClassicalMLSystem ;
    skos:prefLabel              "Consumer Credit Risk Scoring System"@en ;
    skos:definition         "XGBoost model assigning credit risk scores used in automated underwriting decisions for consumer lending. Deployed on AWS SageMaker. Subject to SR 11-7, EBA AI guidelines, and EU AI Act Annex III §5b (access to financial services)."@en ;
    ex:systemOwner          "Credit Risk / Model Office team" ;
    ex:processesPersonalData true ;
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         false ;
    ex:dataRegion           "eu-central-1" ;
    ex:hostedOn             ex:AWSSageMakerDomain ;
    ex:deployedInDomain     ai:Finance ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    ex:riskClassifiedAs         ai:HighRisk ;
    ex:subjectToRequirement     euai:HighRiskEssentialServices ;   # credit = access to services
    ex:subjectToRequirement     euai:RiskManagementSystem ;
    ex:subjectToRequirement     euai:DataGovernance ;
    ex:subjectToRequirement     euai:TechnicalDocumentation ;
    ex:subjectToRequirement     euai:RecordKeeping ;
    ex:subjectToRequirement     euai:HumanOversightRequirement ;
    ex:subjectToRequirement     euai:AccuracyRobustnessRequirement ;
    ex:subjectToRequirement     euai:RightToExplanation ;           # GDPR Art. 22 + EU AI Act
    ex:requiresAssessment       euai:ConformityAssessmentRequirement ;

    # ── SR 11-7 controls ─────────────────────────────────────────────────────
    ex:subjectToControl sr117:ModelDevelopment ;
    ex:subjectToControl sr117:ModelDocumentation ;
    ex:subjectToControl sr117:ModelTesting ;
    ex:subjectToControl sr117:ModelValidation ;
    ex:subjectToControl sr117:ConceptualSoundness ;
    ex:subjectToControl sr117:OngoingMonitoringSR ;
    ex:subjectToControl sr117:OutcomesAnalysis ;
    ex:subjectToControl sr117:ModelInventory ;
    ex:subjectToControl sr117:ThreeLinesOfDefence ;
    ex:subjectToControl sr117:ModelRiskAppetite ;

    # ── EBA AI controls ───────────────────────────────────────────────────────
    ex:subjectToControl eba:ICTRiskFramework ;
    ex:subjectToControl eba:AIModelExplainabilityEBA ;  # SHAP scores for credit decisions
    ex:subjectToControl eba:AIBiasTestingEBA ;
    ex:subjectToControl eba:DataQualityEBA ;
    ex:subjectToControl eba:ModelValidationEBA ;
    ex:subjectToControl eba:AIGovernanceCommitteeEBA ;
    ex:subjectToControl eba:SupervisoryReportingEBA ;

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:MS1 ;
    ex:subjectToControl nrmf:MS3 ;   # ECOA / fair lending bias testing
    ex:subjectToControl nrmf:MS4 ;
    ex:subjectToControl nrmf:MG1 ;
    ex:subjectToControl nrmf:MG2 ;

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A8AILifecycle ;
    ex:subjectToControl iso42001:A10Documentation ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace ai:DiscriminationHarm ;   # disparate impact on protected classes
    ex:bearsFace ai:FinancialHarm ;        # incorrect credit decisions
    ex:bearsFace sr117:ModelRisk ;
    ex:bearsFace sr117:ModelUncertainty ;

    # ── Assessments required ──────────────────────────────────────────────────
    ex:requiresAssessment ai:ConformityAssessment ;
    ex:requiresAssessment ai:BiasAudit ;
    ex:requiresAssessment ai:RiskAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 6.  RAG Document Search (Limited Risk — chatbot-like; internal only)
# ══════════════════════════════════════════════════════════════════════════════

ex:RAGDocumentSearch
    a ex:GenerativeAISystem ;
    skos:prefLabel              "Internal RAG Document Q&A System"@en ;
    skos:definition         "Azure OpenAI Service (GPT-4o) + Azure AI Search for document retrieval. Employees query policy manuals, contracts, and technical specs. PII may appear in documents; no customer data. Classified Limited Risk (chatbot disclosure obligation)."@en ;
    ex:systemOwner          "Knowledge Management / Enterprise IT team" ;
    ex:processesPersonalData true ;    # internal employee documents may contain PII
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         true ;
    ex:dataRegion           "northeurope" ;
    ex:hostedOn             ex:K8sProdCluster, ex:AzureOpenAIService ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    ex:riskClassifiedAs     euai:LimitedRisk ;
    ex:subjectToRequirement euai:TransparencyObligation ;     # employees must know it's AI
    ex:subjectToRequirement euai:HumanOversightRequirement ;

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:GV5 ;
    ex:subjectToControl nrmf:GV6 ;   # Azure/OpenAI supply chain
    ex:subjectToControl nrmf:MP1 ;
    ex:subjectToControl nrmf:MS4 ;
    ex:subjectToControl nrmf:MG2 ;

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A9SupplyChain ;
    ex:subjectToControl iso42001:A10Documentation ;

    # ── OWASP LLM risks ───────────────────────────────────────────────────────
    ex:bearsFace owasp:LLM01_PromptInjection ;
    ex:bearsFace owasp:LLM06_SensitiveInfoDisclosure ;
    ex:bearsFace saif:MemoryPoisoningRAG ;       # RAG store poisoning via document upload

    ex:subjectToControl owasp:PromptValidation ;
    ex:subjectToControl owasp:OutputValidation ;

    # ── MITRE ATLAS risks ─────────────────────────────────────────────────────
    ex:bearsFace atlas:InitialAccess ;           # unauthorised document injection
    ex:bearsFace atlas:DefenceEvasion ;          # prompt crafted to bypass guardrails

    ex:requiresAssessment ai:RedTeamExercise ;
    ex:requiresAssessment ai:RiskAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 7.  Customer Churn Predictor (Minimal Risk — propensity modelling)
# ══════════════════════════════════════════════════════════════════════════════

ex:CustomerChurnPredictor
    a ex:ClassicalMLSystem ;
    skos:prefLabel              "Customer Churn Propensity Model"@en ;
    skos:definition         "Random forest model scoring likelihood of customer churn in the next 90 days. Scores inform outbound retention campaigns. Hosted on Salesforce Einstein Analytics. Processes behavioural data but no consequential automated decisions on individuals."@en ;
    ex:systemOwner          "Customer Success / Revenue Operations team" ;
    ex:processesPersonalData true ;   # customer behavioural data
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         true ;
    ex:dataRegion           "eu-west-1" ;
    ex:hostedOn             ex:SaaSSalesforceEinstein ;
    ex:deployedInDomain     ai:Finance ;       # commercial outcome decisions

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    # No direct consequential decision on individuals → Minimal Risk
    # BUT: personal data profiling → GDPR obligations remain
    ex:riskClassifiedAs     ai:MinimalRisk ;
    ex:subjectToRequirement euai:TransparencyObligation ;  # voluntary best practice

    # ── NIST AI RMF controls ──────────────────────────────────────────────────
    ex:subjectToControl nrmf:GV5 ;    # include in AI inventory
    ex:subjectToControl nrmf:GV6 ;    # Salesforce supply chain
    ex:subjectToControl nrmf:MP1 ;    # deployment context doc
    ex:subjectToControl nrmf:MS4 ;    # churn model drift monitoring

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A9SupplyChain ;
    ex:subjectToControl iso42001:A10Documentation ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace ai:PrivacyHarm ;     # profiling of individuals for commercial decisions

    ex:requiresAssessment ai:RiskAssessment ;
.

# ══════════════════════════════════════════════════════════════════════════════
# 8.  Code Security Scanner (Minimal Risk — developer tooling)
# ══════════════════════════════════════════════════════════════════════════════

ex:CodeSecurityScannerAI
    a ex:GenerativeAISystem ;
    skos:prefLabel              "AI-Powered Code Security Scanner"@en ;
    skos:definition         "LLM-augmented SAST/SCA tool reviewing pull requests for security vulnerabilities, secrets, and dependency CVEs. Hosted on K8s; integrates with GitHub Copilot for suggested fixes. Internal tool only — no customer-facing decisions."@en ;
    ex:systemOwner          "Application Security / Platform Engineering team" ;
    ex:processesPersonalData false ;
    ex:processesSpecialCategoryData false ;
    ex:thirdPartyAI         true ;    # GitHub Copilot for fix suggestions
    ex:dataRegion           "eu-west-1" ;
    ex:hostedOn             ex:K8sProdCluster, ex:SaaSGitHubCopilot ;

    # ── Regulatory risk tier ──────────────────────────────────────────────────
    ex:riskClassifiedAs     ai:MinimalRisk ;

    # ── NIST AI RMF / SAIF controls ──────────────────────────────────────────
    ex:subjectToControl nrmf:GV5 ;
    ex:subjectToControl nrmf:GV6 ;    # GitHub / Microsoft supply chain risk
    ex:subjectToControl nrmf:MS4 ;    # track false-negative rate (missed vulns)

    # ── Google SAIF ───────────────────────────────────────────────────────────
    ex:subjectToControl saif:ExpandSecureFoundation ;

    # ── ISO 42001 controls ────────────────────────────────────────────────────
    ex:subjectToControl iso42001:A9SupplyChain ;

    # ── Risks ─────────────────────────────────────────────────────────────────
    ex:bearsFace owasp:LLM05_SupplyChainVulnerabilities ;  # poisoned Copilot suggestions
    ex:bearsFace owasp:LLM09_Overreliance ;    # developers trust AI fix suggestions blindly
    ex:bearsFace atlas:MLAttackStaging ;       # adversarially crafted code to fool scanner

    ex:requiresAssessment ai:RiskAssessment ;
.
