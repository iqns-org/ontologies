@prefix saas-assets:      <https://iqns.org/v1/enterprise-example#> .
@prefix ai:      <https://iqns.org/v1/ai#> .
@prefix euai:    <https://iqns.org/v1/eu-ai-act#> .
@prefix nrmf:    <https://iqns.org/v1/nist-ai-rmf#> .
@prefix iso42001:<https://iqns.org/v1/iso-42001#> .
@prefix owasp:   <https://iqns.org/v1/owasp-llm#> .
@prefix saif:    <https://iqns.org/v1/google-saif#> .
@prefix atlas:   <https://iqns.org/v1/mitre-atlas#> .
@prefix eba:     <https://iqns.org/v1/eba-ai#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

saas-assets:SaaSontology a owl:Ontology ;
    dct:title       "Enterprise SaaS AI Service Assets"@en ;
    skos:definition "Third-party SaaS products with embedded AI capabilities used by the enterprise, mapped to IQ:NS third-party risk controls."@en ;
    owl:versionInfo "0.1" ;
    owl:imports     <https://iqns.org/v1/enterprise-example> ;
.

# ══════════════════════════════════════════════════════════════════════════════
# Salesforce Einstein
# ══════════════════════════════════════════════════════════════════════════════

saas-assets:SaaSSalesforceEinstein
    a saas-assets:SaaSAIService ;
    skos:prefLabel       "Salesforce Einstein (CRM AI)"@en ;
    skos:definition  "Salesforce Einstein features embedded in Sales Cloud and Service Cloud: Opportunity Scoring, Lead Scoring, Next Best Action, Einstein Conversation Mining, and Customer Churn Prediction. Processes sales interaction data and customer behavioural signals. EU org data stays within Salesforce EU data centre (Frankfurt)."@en ;
    saas-assets:vendor        "Salesforce" ;
    saas-assets:dataRegion    "eu-central-1 (Salesforce Frankfurt DC)" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Non-consequential commercial ML → Minimal Risk (EU AI Act)
    # But processes personal data → GDPR / third-party risk obligations

    # ── Third-party risk controls ─────────────────────────────────────────────
    saas-assets:implementsNatively iso42001:A9SupplyChain ;    # Salesforce is a critical AI vendor — DPA required
    saas-assets:implementsNatively nrmf:GV6 ;                 # Salesforce ISO 27001, SOC2 Type II, CSA STAR

    # What the ENTERPRISE must implement (not Salesforce)
    saas-assets:subjectToControl iso42001:A9SupplyChain ;      # vendor risk register entry, annual assessment
    saas-assets:subjectToControl nrmf:GV6 ;                   # supply-chain governance
    saas-assets:subjectToControl nrmf:MP1 ;                   # deploy context documentation

    # ── EBA (if enterprise is a bank) ─────────────────────────────────────────
    # Salesforce = critical ICT third-party provider under DORA (if applicable)
    saas-assets:subjectToControl eba:ICTAssetManagement ;
    saas-assets:subjectToControl eba:ThirdPartyRiskEBA ;
    saas-assets:subjectToControl eba:OperationalResilienceEBA ;

    # ── Risks ────────────────────────────────────────────────────────────────
    saas-assets:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # embedded AI model updates outside enterprise control
    saas-assets:bearsFace ai:PrivacyHarm ;           # customer PII in CRM used for ML training by Salesforce
    saas-assets:bearsFace ai:VendorLockIn ;          # proprietary scoring models → opacity
.

# ══════════════════════════════════════════════════════════════════════════════
# Workday AI
# ══════════════════════════════════════════════════════════════════════════════

saas-assets:SaaSWorkdayAI
    a saas-assets:SaaSAIService ;
    skos:prefLabel       "Workday AI (HCM Embedded Intelligence)"@en ;
    skos:definition  "Workday Illuminate and embedded ML features in Workday HCM: Skills Cloud (skills inference from job history), Job Architecture recommendations, Talent Optimisation (flight risk scoring), and Workday AI Recruiting (ATS + screening assist). HIGH RISK under EU AI Act if screening recommendations are acted upon."@en ;
    saas-assets:vendor        "Workday" ;
    saas-assets:dataRegion    "eu-west-1 (Workday Ireland DC)" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Recruitment and HCM AI → HIGH RISK (EU AI Act Annex III §4) if used in decisions
    # The enterprise (deployer) bears the obligation even for third-party SaaS
    saas-assets:subjectToRequirement euai:HighRiskEmployment ;
    saas-assets:subjectToRequirement euai:HumanOversightRequirement ;   # human recruiter must own decision
    saas-assets:subjectToRequirement euai:TransparencyObligation ;      # candidates must be informed of AI use
    saas-assets:subjectToRequirement euai:TechnicalDocumentation ;      # enterprise must obtain doc from Workday

    # ── Third-party risk controls ─────────────────────────────────────────────
    saas-assets:implementsNatively iso42001:A9SupplyChain ;
    saas-assets:implementsNatively nrmf:GV6 ;

    saas-assets:subjectToControl iso42001:A9SupplyChain ;    # annual AI-specific vendor assessment (Art. 28 EU AI Act)
    saas-assets:subjectToControl nrmf:GV6 ;
    saas-assets:subjectToControl nrmf:MP5 ;                 # fundamental rights impact on job candidates
    saas-assets:subjectToControl nrmf:MG1 ;                 # escalation: AI flag must be overrideable by recruiter
    saas-assets:subjectToControl iso42001:A6InternalOrganisation ; # HR AI governance ownership defined

    # ── EBA (if enterprise is a bank) ─────────────────────────────────────────
    saas-assets:subjectToControl eba:ThirdPartyRiskEBA ;
    saas-assets:subjectToControl eba:OperationalResilienceEBA ;

    # ── Risks ────────────────────────────────────────────────────────────────
    saas-assets:bearsFace ai:DiscriminationHarm ;           # bias in Skills Cloud or talent flight risk models
    saas-assets:bearsFace ai:PrivacyHarm ;                  # employee performance and salary data
    saas-assets:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # model updates without notice
    saas-assets:bearsFace ai:ReputationalHarm ;             # legally challenged screening outcomes
.

# ══════════════════════════════════════════════════════════════════════════════
# GitHub Copilot
# ══════════════════════════════════════════════════════════════════════════════

saas-assets:SaaSGitHubCopilot
    a saas-assets:SaaSAIService ;
    skos:prefLabel       "GitHub Copilot (Code Assistance)"@en ;
    skos:definition  "GitHub Copilot Business deployed for the engineering organisation (~800 engineers). Provides IDE inline code completion (VS Code, IntelliJ) and GitHub Copilot Chat. Copilot Workspace enabled for sprint tasks. Enterprise licence: no telemetry training on company code; Entra ID SSO; audit log in GHEC."@en ;
    saas-assets:vendor        "GitHub (Microsoft)" ;
    saas-assets:dataRegion    "us-east-1 (GitHub infrastructure)" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Developer tooling, no customer-facing decisions → Minimal Risk
    # But: code quality and security implications

    # ── Third-party risk controls ─────────────────────────────────────────────
    saas-assets:implementsNatively nrmf:GV6 ;              # GitHub SOC2 Type II, ISO 27001
    saas-assets:implementsNatively iso42001:A9SupplyChain ; # in AI vendor register
    saas-assets:subjectToControl nrmf:GV6 ;
    saas-assets:subjectToControl nrmf:GV5 ;                # included in AI system inventory
    saas-assets:subjectToControl iso42001:A9SupplyChain ;

    # ── Risks ────────────────────────────────────────────────────────────────
    saas-assets:bearsFace owasp:LLM09_Overreliance ;           # developers accepting insecure or incorrect code
    saas-assets:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # Copilot suggesting known-vulnerable patterns
    saas-assets:bearsFace owasp:LLM06_SensitiveInfoDisclosure ;    # source code / secrets in prompt context sent to API
    saas-assets:bearsFace ai:SecurityHarm ;                    # introduction of security defects at scale
    saas-assets:bearsFace ai:LegalHarm ;                       # copyright / licence questions on suggested code
.

# ══════════════════════════════════════════════════════════════════════════════
# ServiceNow AI (ITSM / HRSD)
# ══════════════════════════════════════════════════════════════════════════════

saas-assets:SaaSServiceNowAI
    a saas-assets:SaaSAIService ;
    skos:prefLabel       "ServiceNow AI (Now Intelligence)"@en ;
    skos:definition  "ServiceNow Now Intelligence features: Virtual Agent (ITSM chatbot), Predictive Intelligence (incident routing, change risk), NLU classifier, and Now Assist (GenAI summarisation with private LLM). Used by IT Operations and HR Service Delivery. Virtual Agent interactions classified as Limited Risk (chatbot)."@en ;
    saas-assets:vendor        "ServiceNow" ;
    saas-assets:dataRegion    "eu-west-1 (ServiceNow EU DC)" ;

    # ── Regulatory scope ──────────────────────────────────────────────────────
    # Virtual Agent chatbot → EU AI Act Art. 50 disclosure
    saas-assets:implementsNatively euai:TransparencyObligation ;   # Virtual Agent discloses bot identity

    # ── Third-party risk controls ─────────────────────────────────────────────
    saas-assets:implementsNatively iso42001:A9SupplyChain ;
    saas-assets:implementsNatively nrmf:GV6 ;
    saas-assets:subjectToControl iso42001:A9SupplyChain ;
    saas-assets:subjectToControl nrmf:GV6 ;
    saas-assets:subjectToControl nrmf:GV5 ;

    # ── EBA (if enterprise is a bank) ─────────────────────────────────────────
    saas-assets:subjectToControl eba:ICTAssetManagement ;
    saas-assets:subjectToControl eba:ThirdPartyRiskEBA ;

    # ── Risks ────────────────────────────────────────────────────────────────
    saas-assets:bearsFace ai:PrivacyHarm ;                     # employee HR tickets contain sensitive PII
    saas-assets:bearsFace owasp:LLM09_Overreliance ;            # IT staff trusting AI incident routing blindly
    saas-assets:bearsFace owasp:LLM05_SupplyChainVulnerabilities ; # GenAI feature updates without enterprise testing
.

# ══════════════════════════════════════════════════════════════════════════════
# OpenAI Direct API (Shadow / Experimental)
# ══════════════════════════════════════════════════════════════════════════════

saas-assets:SaaSOpenAIDirectAPI
    a saas-assets:SaaSAIService ;
    skos:prefLabel       "OpenAI Direct API (Experimental / Shadow)"@en ;
    skos:definition  "Direct api.openai.com API access used by several product teams outside the approved Azure OpenAI channel. No enterprise data boundary, no audit log, no DPA in place. Identified as shadow AI risk during AI audit. Remediation plan: migrate all use cases to AzureOpenAIService or terminate."@en ;
    saas-assets:vendor        "OpenAI" ;
    saas-assets:dataRegion    "us (openai.com)" ;

    # ── Significant compliance gaps ───────────────────────────────────────────
    # Mark all the controls that are NOT natively provided — enterprise must remediate

    # No DPA → GDPR Art. 28 breach risk
    # No zero-retention → prompt data retention policy unclear
    # No EU data residency → international transfer risk (GDPR Ch. V)
    # No audit log → record-keeping failure for EU AI Act

    saas-assets:subjectToControl iso42001:A9SupplyChain ;    # URGENT: DPA required or use prohibited
    saas-assets:subjectToControl nrmf:GV6 ;                 # supply-chain: no enterprise-grade SLA
    saas-assets:subjectToControl euai:TransparencyObligation ; # employee-facing outputs may not disclose AI

    # ── Risks (elevated — unmanaged shadow AI) ────────────────────────────────
    saas-assets:bearsFace ai:PrivacyHarm ;                     # PII and confidential data in uncontrolled prompts
    saas-assets:bearsFace ai:SecurityHarm ;                    # proprietary IP in prompts with no retention control
    saas-assets:bearsFace owasp:LLM06_SensitiveInfoDisclosure ;
    saas-assets:bearsFace owasp:LLM09_Overreliance ;
    saas-assets:bearsFace owasp:LLM05_SupplyChainVulnerabilities ;
    saas-assets:bearsFace ai:LegalHarm ;                       # no contractual basis for personal data processing

    # Recommended remediation:
    # saas-assets:replacedBy saas-assets:AzureOpenAIService .           # (uncomment when migration complete)
.
