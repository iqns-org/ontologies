# ════════════════════════════════════════════════════════════════════
# RISK LEVELS ALIGNMENT
# ════════════════════════════════════════════════════════════════════

ai-crosswalk:RiskLevels a skos:Collection ;
    skos:prefLabel "Risk Level Tiers"@en ;
    skos:member ai:UnacceptableRisk ;
    skos:member ai:HighRisk ;
    skos:member ai:LimitedRisk ;
    skos:member ai:MinimalRisk ;
    skos:member euai:UnacceptableRiskTier ;
    skos:member euai:HighRiskTier ;
    skos:member euai:LimitedRiskTier ;
    skos:member euai:MinimalRiskTier ;
    skos:member ca:ImpactLevelIV ;
    skos:member ca:ImpactLevelIII ;
    skos:member ca:ImpactLevelII ;
    skos:member ca:ImpactLevelI ;
    skos:member fda:SaMDRiskClass ;
.

euai:UnacceptableRiskTier   skos:exactMatch ai:UnacceptableRisk ; skos:broadMatch ca:ImpactLevelIV .
euai:HighRiskTier           skos:exactMatch ai:HighRisk ;         skos:broadMatch ca:ImpactLevelIII .
euai:LimitedRiskTier        skos:exactMatch ai:LimitedRisk ;      skos:broadMatch ca:ImpactLevelII .
euai:MinimalRiskTier        skos:exactMatch ai:MinimalRisk ;       skos:broadMatch ca:ImpactLevelI .

