.

iso24027:BiasSourceType
    skos:relatedMatch euai:HighRiskAISystem ;
    skos:relatedMatch eba:AIBiasTestingEBA ;
    skos:relatedMatch onc:AlgorithmBiasEvaluationONC ;
    skos:relatedMatch ca:QualityAssuranceTestingCA ;
    skos:relatedMatch msft:FairnessMetricsRequirement ;
.
onc:AlgorithmBiasEvaluationONC
    skos:exactMatch eba:AIBiasTestingEBA ;
    skos:exactMatch msft:FairnessMetricsRequirement ;
    skos:broadMatch ca:QualityAssuranceTestingCA ;
    skos:relatedMatch iso242027:BiasSourceType ;
.
msft:FairnessMSFT
    skos:exactMatch pai:FairAndNonDiscriminatory ;
    skos:exactMatch un:FairnessNonDiscrimination ;
    skos:exactMatch n1001:Fairness ;
    skos:broadMatch onc:EquityONC ;
.

