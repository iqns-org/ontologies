@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ai-crosswalk:Ontology a owl:Ontology ;
    dct:title  "IQ:NS Compliance Crosswalk — SKOS Alignments Across All Frameworks"@en ;
    skos:definition "N×M mapping of equivalent and related concepts across all ai compliance frameworks, anchored via the ai: core vocabulary."@en .

# Enterprise+IT/cyber/HSE frameworks in AI crosswalk
ai-crosswalk:EnterpriseGovernance a skos:Collection ;
    skos:prefLabel "Enterprise Governance and Risk Architecture"@en ;
    skos:member cobit:GovernanceFramework ;
    skos:member iso45001:ISO45001 ;
    skos:member soc2:SOC2 ;
    skos:member iso42001:ISO42001 ;
    skos:member nrmf:NISTRMF ;
    skos:member enterprise:RiskManagement ;
.


ai-crosswalk:Scheme a skos:ConceptScheme ;
    skos:prefLabel "IQ:NS Compliance Crosswalk"@en .

# ════════════════════════════════════════════════════════════════════
# DIMENSION: TRANSPARENCY / EXPLAINABILITY
# ════════════════════════════════════════════════════════════════════

ai-crosswalk:Transparency a skos:Collection ;
    skos:prefLabel "Transparency and Explainability"@en ;
    skos:member ai:Transparency ;
    skos:member ai:Explainability ;
    skos:member euai:TransparencyObligation ;
    skos:member n1001:Transparency ;
    skos:member nrmf:TrustworthinessCharacteristic ;
    skos:member oecd:TransparencyOECD ;
    skos:member un:TransparencyUNESCO ;
    skos:member msft:TransparencyMSFT ;
    skos:member sg:ModelInterpretability ;
    skos:member ca:ExplanationOfDecision ;
    skos:member ieee7000:T7001 ;
    skos:member iso25059:Interpretability ;
    skos:member iso24028:TrustworthinessProperty ;
    skos:member pai:TransparentAndExplainablePAI ;
    skos:member eba:AIModelExplainabilityEBA ;
    skos:member onc:TransparencyONC ;
    skos:member fda:TransparencyToUsersPatients ;
    skos:member cn:OpenGovernance ;
.

euai:TransparencyObligation
    skos:exactMatch n1001:Transparency ;
    skos:exactMatch msft:TransparencyMSFT ;
    skos:exactMatch oecd:TransparencyOECD ;
    skos:exactMatch un:TransparencyUNESCO ;
    skos:exactMatch pai:TransparentAndExplainablePAI ;
    skos:broadMatch sg:DecisionAuditability ;
    skos:broadMatch ca:ExplanationOfDecision ;
    skos:broadMatch eba:AIModelExplainabilityEBA ;
.
n1001:Transparency
    skos:exactMatch msft:TransparencyMSFT ;
    skos:exactMatch oecd:TransparencyOECD ;
    skos:broadMatch sg:ModelInterpretability ;
    skos:broadMatch onc:TransparencyONC ;
    skos:broadMatch fda:TransparencyToUsersPatients ;
.
iso25059:Interpretability
    skos:exactMatch sg:ModelInterpretability ;
    skos:broadMatch eba:AIModelExplainabilityEBA ;
    skos:relatedMatch msft:ModelCardsMSFT ;
.

