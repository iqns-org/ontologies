# ──────────────────────────────────────────────────────────────────────────────
# 15 — Risk Distribution by Category
# Produces risk scoring by category for bar chart visualization.
#
# CUJ: Visualize dominant AI risk categories for prioritization.
# ──────────────────────────────────────────────────────────────────────────────

PREFIX ai:   <https://iqns.org/v1/ai#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?category (SUM(?riskValue) AS ?score)
WHERE {
    ?risk a ai:Risk ;
          ai:hasRiskCategory ?category ;
          ai:hasRiskScore ?riskValue .
    ?category skos:prefLabel ?categoryLabel .
    FILTER(LANG(?categoryLabel) = "en" || LANG(?categoryLabel) = "")
}
GROUP BY ?category
ORDER BY DESC(?score)
