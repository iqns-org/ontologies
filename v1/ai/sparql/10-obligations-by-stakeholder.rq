# ─────────────────────────────────────────────────────────────────────────────
# 10  Obligations by Stakeholder Role
# Purpose : Show which stakeholder roles (Developer, Deployer, Operator…) bear
#           which Obligations under each framework.
# Use case: CISO RACI mapping — determine who in the org owns each obligation.
# ─────────────────────────────────────────────────────────────────────────────

PREFIX gg:   <https://iqns.org/v1/ai#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX prov:  <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT
    ?this  
    ?stakeholderLabel
    ?obligationLabel
    ?obligationDef
    ?frameworkLabel
    ?citation
WHERE {
    ?this   a gg:Stakeholder ;
                  skos:prefLabel ?stakeholderLabel .

    ?obligation   a gg:Obligation ;
                  skos:prefLabel ?obligationLabel .

    # Obligations may reference their bearer via dct:subject or similar;
    # also check reverse: frameworks impose obligations with domain defined
    # as a stakeholder type via skos:related or dct:subject pattern.
    {
        ?obligation  dct:subject ?this  .
    }
    UNION
    {
        ?obligation  skos:related ?this  .
    }
    UNION
    {
        # Fall-back: obligation label contains stakeholder label (free-text match)
        BIND( CONTAINS( LCASE(STR(?obligationLabel)), LCASE(STR(?stakeholderLabel)) ) AS ?match )
        FILTER ( ?match = true )
    }

    OPTIONAL { ?obligation skos:definition ?obligationDef . }
    OPTIONAL { ?obligation prov:wasDerivedFrom      ?citation      . }

    OPTIONAL {
        ?fw gg:imposesObligation ?obligation ;
            skos:prefLabel       ?frameworkLabel .
    }

    FILTER ( lang(?stakeholderLabel) = "en" )
    FILTER ( lang(?obligationLabel)  = "en" )
}
ORDER BY ?stakeholderLabel ?frameworkLabel ?obligationLabel
