# ─────────────────────────────────────────────────────────────────────────────
# 14  Principles Catalogue with Cross-Framework Alignment
# Purpose : List all ai:Principle instances with their exactMatch chains to
#           show where multiple frameworks share the same normative value.
# Use case: CISO policy mapping — identify shared principles to unify policies.
# ─────────────────────────────────────────────────────────────────────────────

PREFIX ai:   <https://iqns.org/v1/ai#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dct:  <http://purl.org/dc/terms/>

SELECT DISTINCT
    ?frameworkLabel
    ?principleLabel
    ?principleDefinition
    ?dimensionLabel
    ?alignedPrincipleLabel
    ?alignedFramework
    ?citation
WHERE {
    ?fw        a ai:Framework ;
               skos:prefLabel    ?frameworkLabel ;
               ai:hasPrinciple   ?principle .

    ?principle a ai:Principle ;
               skos:prefLabel    ?principleLabel .

    OPTIONAL { ?principle skos:definition  ?principleDefinition . }
    OPTIONAL { ?principle dct:source       ?citation            . }
    OPTIONAL {
        ?principle ai:mappedToDimension ?dim .
        ?dim skos:prefLabel ?dimensionLabel .
    }
    OPTIONAL {
        ?principle skos:exactMatch ?aligned .
        ?aligned   skos:prefLabel  ?alignedPrincipleLabel .
        ?alignedFw a ai:Framework ;
                   ai:hasPrinciple ?aligned ;
                   skos:prefLabel  ?alignedFramework .
    }

    FILTER ( lang(?frameworkLabel) = "en" )
    FILTER ( lang(?principleLabel) = "en" )
}
ORDER BY ?frameworkLabel ?principleLabel
