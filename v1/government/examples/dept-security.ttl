@prefix dept-security: <https://iqns.org/v1/government/examples/dept-security#> .
@prefix ex:     <https://iqns.org/v1/example#> .
@prefix gov:    <https://iqns.org/v1/govtgraph#> .
@prefix ai:     <https://iqns.org/v1/ai#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix fedramp: <https://iqns.org/v1/fedramp#> .

dept-security:FedCloudPortal a ai:System ;
    a gov:GovernmentAgency ;
    skos:prefLabel "Department of Security Cloud Portal"@en ;
    ai:mappedToDimension gov:CyberResilience ;
    ai:appliesToLifecycle gov:Protect ;
    prov:wasDerivedFrom "GSA System Inventory G-99" ;
    # Authorisation Status
    ai:implementsControl fedramp:ModerateBaseline ;
    ai:implementsControl fedramp:ContinuousMonitoring ;
.
